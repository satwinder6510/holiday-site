  <slot name="head" />
</head>
<body>
  <slot />

  <!-- Traffic source tracking -->
  <script is:inline>
    (function () {
      if (sessionStorage.getItem('lead_source')) return;
      var params = new URLSearchParams(window.location.search);
      var src = params.get('utm_source');
      if (!src && document.referrer) {
        try {
          var host = new URL(document.referrer).hostname.replace('www.', '');
          if (host.indexOf('google') >= 0) src = 'Google';
          else if (host.indexOf('bing') >= 0) src = 'Bing';
          else if (host.indexOf('facebook') >= 0 || host.indexOf('fb.') >= 0) src = 'Facebook';
          else if (host.indexOf('instagram') >= 0) src = 'Instagram';
          else if (host.indexOf('twitter') >= 0 || host.indexOf('x.com') >= 0) src = 'Twitter/X';
          else if (host.indexOf('tiktok') >= 0) src = 'TikTok';
          else if (host.indexOf('youtube') >= 0) src = 'YouTube';
          else if (host.indexOf(window.location.hostname) >= 0) src = null;
          else src = host;
        } catch (e) { src = null; }
      }
      sessionStorage.setItem('lead_source', src || 'Direct');
      if (!sessionStorage.getItem('landing_page')) {
        sessionStorage.setItem('landing_page', window.location.pathname);
      }
    })();
  </script>

  <!-- Cookie Banner (UK PECR/GDPR) -->
  <div id="cookie-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; background:#073140; color:#fff; padding:14px 20px; z-index:9999; font-family:'BentonSans',sans-serif; font-size:14px; line-height:22px;">
    <div style="max-width:1240px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;">
      <p style="margin:0; flex:1; min-width:200px;">We use cookies to improve your experience on our site. By continuing to browse, you accept our use of cookies. <a href="/cookies-policy" style="color:#20A1AA; text-decoration:underline;">Cookie Policy</a></p>
      <button id="cookie-accept" style="background:#20A1AA; color:#fff; border:none; padding:8px 24px; border-radius:4px; font-size:14px; font-family:'BentonSans',sans-serif; font-weight:700; cursor:pointer; white-space:nowrap;">Accept</button>
    </div>
  </div>
  <script is:inline>
    (function () {
      if (!document.cookie.includes('cookie_consent=1')) {
        document.getElementById('cookie-banner').style.display = 'block';
      }
      document.getElementById('cookie-accept').addEventListener('click', function () {
        document.cookie = 'cookie_consent=1; path=/; max-age=' + (365 * 24 * 60 * 60) + '; SameSite=Lax';
        document.getElementById('cookie-banner').style.display = 'none';
      });
    })();
  </script>

  <!-- HappyFox Live Chat (9am–6pm GMT only) -->
  <script is:inline>
    (function () {
      var hour = new Date().getUTCHours();
      if (hour >= 9 && hour < 18) {
        window.HFCHAT_CONFIG = {
          EMBED_TOKEN: '0799b060-00fb-11f1-a7bb-77728896a359',
          ASSETS_URL: 'https://widget.happyfoxchat.com/v2/visitor'
        };
        var scriptTag = document.createElement('script');
        scriptTag.type = 'text/javascript';
        scriptTag.async = true;
        scriptTag.src = window.HFCHAT_CONFIG.ASSETS_URL + '/js/widget-loader.js';
        var s = document.getElementsByTagName('script')[0];
        s.parentNode.insertBefore(scriptTag, s);
      }
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/fonts.css';
  @import '../styles/global.css';
</style>
