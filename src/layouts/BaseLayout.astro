---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Holidays - Flights and Packages offer Quality City Breaks, Beach Holidays, Multi Centre Holidays, Tailor Made Holidays and Private Tours at Affordable Prices.',
  image,
  type = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image || 'https://holidays.flightsandpackages.com/images/og-default.jpg';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  '@id': 'https://holidays.flightsandpackages.com/#organization',
  name: 'Flights and Packages',
  url: 'https://holidays.flightsandpackages.com',
  telephone: '+44 208 183 0518',
  email: 'info@holidays.flightsandpackages.com',
  description: 'Quality City Breaks, Beach Holidays, Multi Centre Holidays, Tailor Made Holidays and Private Tours at Affordable Prices.',
  logo: {
    '@type': 'ImageObject',
    url: 'https://holidays.flightsandpackages.com/icons/flights-and-packages-logo.png',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Airport House, Purley Way',
    addressLocality: 'Croydon',
    postalCode: 'CR0 0XZ',
    addressCountry: 'GB',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+44 208 183 0518',
    contactType: 'customer service',
    availableLanguage: 'English',
    areaServed: 'GB',
  },
  sameAs: [
    'https://www.facebook.com/flightsandpackages',
  ],
  areaServed: 'GB',
  priceRange: '$$',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Flights and Packages',
  url: 'https://holidays.flightsandpackages.com',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://holidays.flightsandpackages.com/Holidays/search?destination={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#20A1AA" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <link rel="canonical" href={canonicalURL.href} />

  {noindex && <meta name="robots" content="noindex, follow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="Flights and Packages" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Font Preloads -->
  <link rel="preload" href="/fonts/BentonSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/BentonSans-Medium.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/BentonSans-Bold.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/CaslonGraphiqueEF.woff2" as="font" type="font/woff2" crossorigin />

  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <!-- WebSite Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Facebook Pixel -->
  <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '2922972984621050');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=2922972984621050&ev=PageView&noscript=1" /></noscript>

  <!-- PostHog Analytics -->
  <script is:inline>
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group identify setPersonProperties setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags resetGroups onFeatureFlags addFeatureFlagsHandler onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
