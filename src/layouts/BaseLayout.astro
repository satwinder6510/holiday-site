---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Holidays - Flights and Packages offer Quality City Breaks, Beach Holidays, Multi Centre Holidays, Tailor Made Holidays and Private Tours at Affordable Prices.',
  image,
  type = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image || 'https://holidays.flightsandpackages.com/images/og-default.jpg';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  name: 'Flights and Packages',
  url: 'https://holidays.flightsandpackages.com',
  telephone: '0208 183 0518',
  email: 'info@holidays.flightsandpackages.com',
  description: 'Quality City Breaks, Beach Holidays, Multi Centre Holidays, Tailor Made Holidays and Private Tours at Affordable Prices.',
};
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, minimum-scale=1.0, maximum-scale=2.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <link rel="canonical" href={canonicalURL.href} />

  {noindex && <meta name="robots" content="noindex, follow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="Flights and Packages" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Font Preloads -->
  <link rel="preload" href="/fonts/BentonSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/BentonSans-Medium.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/BentonSans-Bold.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/CaslonGraphiqueEF.woff2" as="font" type="font/woff2" crossorigin />

  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/fonts.css';
  @import '../styles/global.css';
</style>
