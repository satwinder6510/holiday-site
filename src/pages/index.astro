---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import MobileNav from '../components/MobileNav.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import SearchForm from '../components/SearchForm.astro';
import WelcomeSection from '../components/WelcomeSection.astro';
import OfferCarousel from '../components/OfferCarousel.astro';
import CountriesSection from '../components/CountriesSection.astro';
import FeaturedTour from '../components/FeaturedTour.astro';
import CollectionsCarousel from '../components/CollectionsCarousel.astro';
import DestinationsCarousel from '../components/DestinationsCarousel.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import MobileCallCTA from '../components/MobileCallCTA.astro';
import { fetchHomepageData } from '../lib/api';

const data = await fetchHomepageData();
---

<BaseLayout title="Quality Holidays at Affordable Prices | Holidays - Flights and Packages">
  <Header />
  <MobileNav />

  <div class="relative">
    <HeroCarousel slides={data?.heroSlides} />
    <SearchForm />
  </div>

  <WelcomeSection />
  <OfferCarousel offers={data?.specialOffers} />
  <CountriesSection />
  <FeaturedTour tour={data?.featuredTour} />
  <CollectionsCarousel />
  <DestinationsCarousel />

  <Newsletter />
  <Footer />
  <MobileCallCTA />
</BaseLayout>
