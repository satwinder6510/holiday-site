---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import MobileNav from '../../components/MobileNav.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import MobileCallCTA from '../../components/MobileCallCTA.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import { destinations } from '../../data/destinations';
import { countries } from '../../data/countries';

export function getStaticPaths() {
  return destinations.map((d) => {
    const slug = d.name.replace(/\s+/g, '-');
    return {
      params: { slug },
      props: { destination: d },
    };
  });
}

const { destination } = Astro.props;
const regionCountries = countries.filter((c) => c.region === destination.name);

let titleText = destination.name + ' Holidays';
if (destination.name === 'Africa') titleText = 'Holidays in Africa';
else if (destination.name === 'Asia') titleText = 'Holidays to Asia';

const bannerImage = `https://admin.citiesandbeaches.com/images/destinations/${destination.name}_banner.jpg`;

const introTexts: Record<string, { short: string; long: string }> = {
  'Europe': {
    short: 'From the sun-drenched coastlines of the Mediterranean to the fairy-tale cities of Central Europe, our European holiday packages combine flights, hotels and unforgettable experiences into one seamless trip.',
    long: 'Whether you are exploring the canals of Venice, soaking up the Greek islands, cruising the Rhine or sampling tapas in Barcelona, Europe offers something for every kind of traveller. Browse our destinations below to find your next adventure.',
  },
  'Asia': {
    short: 'Discover the ancient temples, pristine beaches and vibrant cultures of Asia with our expertly curated fly-and-stay packages from UK airports.',
    long: 'From the backwaters of Kerala to the beaches of Bali, the street food of Bangkok to the serenity of Sri Lanka, Asia is a continent of contrasts that rewards every kind of traveller. Explore our destinations below.',
  },
  'Americas': {
    short: 'From the Andes to the Amazon, the Americas offer extraordinary landscapes, rich cultures and once-in-a-lifetime experiences — all with flights included.',
    long: 'Whether you dream of trekking Machu Picchu, exploring Costa Rica\'s rainforests, or road-tripping through the USA, our packages take the hassle out of long-haul travel. Browse our destinations below.',
  },
  'Africa': {
    short: 'Experience the magic of Africa — from wildlife safaris to vibrant cities and stunning Indian Ocean coastlines, all with flights and accommodation included.',
    long: 'Africa offers some of the most extraordinary travel experiences on earth. Whether it\'s the Big Five in Kenya, the souks of Marrakech, or the winelands of South Africa, we\'ll help you find the perfect trip.',
  },
  'Middle East': {
    short: 'Explore the Middle East — a region where ancient heritage meets ultra-modern luxury, with year-round sunshine and world-class hospitality.',
    long: 'From the futuristic skyline of Dubai to the ancient wonders of Egypt, the Middle East offers a fascinating blend of old and new. Our packages include flights and carefully selected hotels.',
  },
  'Indian Ocean': {
    short: 'Escape to the Indian Ocean — turquoise lagoons, powder-white beaches and luxury resorts that define the ultimate tropical getaway.',
    long: 'The Maldives and Mauritius offer two of the world\'s most coveted beach destinations. Whether you\'re looking for an overwater villa, a romantic honeymoon, or a family-friendly resort, our fly-and-stay packages make paradise easy to reach.',
  },
};

const intro = introTexts[destination.name] || { short: `Explore our ${destination.name} holiday destinations.`, long: '' };
---

<BaseLayout title={`${titleText} | Flights and Packages`} description={intro.short} image={bannerImage}>
  <BreadcrumbSchema slot="head" items={[
    { name: 'Home', url: '/' },
    { name: 'Destinations' },
    { name: destination.name },
  ]} />
  <Header />
  <MobileNav />

  <!-- Hero -->
  <section class="dest-hero" style={`background-image: url('${bannerImage}')`}>
    <div class="breadcrumbs">
      <a href="/">Home</a>
      <img src="/icons/breadcrumb-arrow.svg" alt="" class="breadcrumb-icon" />
      <span>Destinations</span>
      <img src="/icons/breadcrumb-arrow.svg" alt="" class="breadcrumb-icon" />
      <span>{destination.name}</span>
    </div>
    <div class="hero-content">
      <div class="hero-subtitle">discover</div>
      <h1>{titleText}</h1>
      <div class="hero-count">{regionCountries.length} {regionCountries.length === 1 ? 'Destination' : 'Destinations'}</div>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro-section section-container">
    <p class="intro-text">{intro.short}</p>
    {intro.long && (
      <p class="intro-text-extra hide">{intro.long}</p>
    )}
    {intro.long && (
      <a class="read-more" href="javascript:void(0)">
        Read more
        <span class="icon-dropdown"></span>
      </a>
    )}
  </section>

  <!-- Countries Grid -->
  <section class="countries-section section-container">
    <p class="section-label">explore</p>
    <h2>Our Destinations</h2>

    <div class="countries-grid">
      {regionCountries.map((country) => (
        <a href={country.href} class="country-card">
          <div class="card-image" style={`background-image: url('${country.image}')`}>
            <div class="card-content">
              <div class="card-name">{country.name}</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Newsletter />
  <Footer />
  <MobileCallCTA />
</BaseLayout>

<style>
  /* Hero */
  .dest-hero {
    margin-top: 100px;
    height: 500px;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    position: relative;
    color: #ffffff;
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 100%;
  }
  @media (max-width: 768px) {
    .dest-hero { margin-top: 50px; height: 400px; }
  }
  @media (max-width: 450px) {
    .dest-hero { height: 300px; }
  }

  .breadcrumbs {
    position: absolute;
    left: 50px;
    top: 10px;
    z-index: 3;
    display: flex;
    align-items: center;
    color: #ffffff;
  }
  @media (max-width: 768px) { .breadcrumbs { left: 20px; } }
  .breadcrumbs a,
  .breadcrumbs span {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 10px;
    line-height: 12px;
    color: #ffffff;
  }
  .breadcrumb-icon {
    padding: 0 5px;
    width: auto;
    height: 8px;
  }

  .hero-content {
    text-align: center;
    padding-bottom: 80px;
  }
  @media (max-width: 768px) { .hero-content { padding-bottom: 0; } }

  .hero-subtitle {
    font-family: "BentonSansBold", sans-serif;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 5px;
    text-transform: uppercase;
    padding-bottom: 14px;
  }

  .hero-content h1 {
    color: #ffffff;
    font-size: 64px;
    line-height: 1;
    padding-bottom: 15px;
    text-shadow: 2px 2px 5px #000;
  }
  @media (max-width: 768px) { .hero-content h1 { font-size: 44px; } }
  @media (max-width: 450px) { .hero-content h1 { font-size: 36px; } }

  .hero-count {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 16px;
    line-height: 27px;
    letter-spacing: 1px;
  }

  /* Intro */
  .intro-section {
    margin-top: 80px;
    margin-bottom: 20px;
  }
  @media (max-width: 768px) { .intro-section { margin-top: 40px; margin-bottom: 10px; } }
  .intro-section p { padding-bottom: 1px; }
  @media (max-width: 768px) { .intro-section p { text-align: justify; } }

  .intro-section .read-more {
    vertical-align: middle;
    font-family: "BentonSansBold", sans-serif;
    color: #424242;
    text-decoration: none;
    display: inline-block;
    margin-top: 15px;
    cursor: pointer;
  }
  .intro-section .read-more .icon-dropdown {
    display: inline-block;
    width: 12px;
    height: 7px;
    background-image: url('/icons/dropdown-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    margin-left: 15px;
    transition: transform 0.3s;
  }
  .intro-section .read-more.expanded .icon-dropdown { transform: rotate(180deg); }

  .hide { display: none; }

  /* Countries Section */
  .countries-section {
    padding-top: 40px;
    padding-bottom: 80px;
  }
  .countries-section .section-label {
    font-family: "BentonSansBold", sans-serif;
    font-size: 14px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: #878787;
    margin-bottom: 8px;
  }
  .countries-section h2 {
    margin-bottom: 45px;
  }

  /* Grid */
  .countries-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
  }
  @media (max-width: 940px) {
    .countries-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 530px) {
    .countries-grid { grid-template-columns: 1fr; }
  }

  /* Card */
  .country-card {
    display: block;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .country-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .card-image {
    width: 100%;
    height: 310px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
  }
  @media (max-width: 768px) {
    .card-image { height: 260px; }
  }
  @media (max-width: 450px) {
    .card-image { height: 220px; }
  }

  /* Compass icon */
  .card-image::before {
    position: absolute;
    z-index: 2;
    content: "";
    display: block;
    background-image: url('/icons/compass-icon.svg');
    background-size: contain;
    background-repeat: no-repeat;
    width: 100px;
    height: 100px;
    bottom: -8px;
    left: -8px;
  }
  @media (max-width: 768px) {
    .card-image::before { width: 78px; height: 78px; bottom: 0; left: -5px; }
  }

  /* Gradient overlay */
  .card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px 30px 24px;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.6) 100%);
    color: #ffffff;
    z-index: 1;
  }

  .card-name {
    font-family: "CaslonGraphiqueEF", Georgia, serif;
    font-size: 28px;
    line-height: 1;
  }
  @media (max-width: 768px) {
    .card-name { font-size: 24px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const readMoreLink = document.querySelector('.read-more');
    const extraText = document.querySelector('.intro-text-extra');
    if (readMoreLink && extraText) {
      readMoreLink.addEventListener('click', () => {
        const isHidden = extraText.classList.contains('hide');
        extraText.classList.toggle('hide');
        readMoreLink.innerHTML = isHidden
          ? 'Read less <span class="icon-dropdown"></span>'
          : 'Read more <span class="icon-dropdown"></span>';
        readMoreLink.classList.toggle('expanded', isHidden);
      });
    }
  });
</script>
