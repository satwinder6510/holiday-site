---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import MobileNav from '../../components/MobileNav.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import MobileCallCTA from '../../components/MobileCallCTA.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import { allBlogs } from '../../data/blogs';

const BLOGS_PER_PAGE = 9;
const totalPages = Math.ceil(allBlogs.length / BLOGS_PER_PAGE);

// Build archive data — group blogs by month/year
const archiveMap = new Map<string, number>();
for (const blog of allBlogs) {
  if (!blog.date) continue;
  // blog.date is like "22 September 2019"
  const parts = blog.date.split(' ');
  if (parts.length >= 3) {
    const key = `${parts[1]} ${parts[2]}`;
    archiveMap.set(key, (archiveMap.get(key) || 0) + 1);
  }
}
const archiveEntries = Array.from(archiveMap.entries());
---

<BaseLayout title="Our Blog | Holidays - Flights and Packages" description="Read the latest travel blogs, destination guides and holiday inspiration from Flights and Packages. Expert tips on city breaks, beach holidays, river cruises and tours across Europe, Asia and beyond.">
  <BreadcrumbSchema slot="head" items={[
    { name: 'Home', url: '/' },
    { name: 'Blog' },
  ]} />
  <Header />
  <MobileNav />
  <PageHero
    title="Our Blog"
    subtitle="read all about it"
    breadcrumbLabel="Blogs"
    backgroundImage="/images/heroes/blog.jpg"
  />

  <section class="blog-list-section">
    <section class="section-container">
      <div class="content">
        <div class="blogs">
          {allBlogs.map((blog, i) => {
            const page = Math.floor(i / BLOGS_PER_PAGE);
            const excerpt = blog.excerpt.length > 130 ? blog.excerpt.substring(0, 130) + '...' : blog.excerpt;
            return (
              <div class={`blog page-${page}`} style={page === 0 ? '' : 'display:none'}>
                <a href={`/blog/${blog.slug}`}>
                  <img src={blog.image} alt={blog.title} class="blog-img" />
                </a>
                <div class="blog-title">{blog.title}</div>
                <div class="blog-date">
                  <img src="/icons/calendar-icon-black.svg" alt="" class="icon-calendar" />
                  {blog.date}
                </div>
                <p>{excerpt}</p>
                <a href={`/blog/${blog.slug}`} class="read-more">
                  Read More
                  <img src="/icons/more-icon.svg" alt="" class="icon-more" />
                </a>
              </div>
            );
          })}
        </div>
        <!-- Pagination -->
        <div class="pagination">
          <ul>
            <li class="disabled"><a class="nav-btn first-btn">&laquo;</a></li>
            <li class="disabled"><a class="nav-btn prev-btn">&lsaquo;</a></li>
            {Array.from({ length: totalPages }, (_, i) => (
              <li class={i === 0 ? 'active' : ''}><a class="page-btn" data-page={i}>{i + 1}</a></li>
            ))}
            <li><a class="nav-btn next-btn">&rsaquo;</a></li>
            <li><a class="nav-btn last-btn">&raquo;</a></li>
          </ul>
        </div>
      </div>
      <div class="sidebar">
        <div class="archive">
          Archive
          <ul>
            {archiveEntries.slice(0, 8).map(([month, count]) => (
              <li>{month}<span>({count})</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </section>

  <Newsletter />
  <Footer />
  <MobileCallCTA />
</BaseLayout>

<script define:vars={{ totalPages: totalPages }}>
  document.addEventListener('DOMContentLoaded', () => {
    let currentPage = 0;
    const total = totalPages;

    function showPage(page) {
      currentPage = page;
      document.querySelectorAll('.blogs .blog').forEach(el => el.style.display = 'none');
      document.querySelectorAll(`.blogs .page-${page}`).forEach(el => el.style.display = '');

      // Update page buttons
      document.querySelectorAll('.pagination .page-btn').forEach(btn => {
        btn.parentElement.classList.toggle('active', parseInt(btn.dataset.page) === page);
      });

      // Update nav buttons
      const firstBtn = document.querySelector('.first-btn');
      const prevBtn = document.querySelector('.prev-btn');
      const nextBtn = document.querySelector('.next-btn');
      const lastBtn = document.querySelector('.last-btn');
      firstBtn.parentElement.classList.toggle('disabled', page === 0);
      prevBtn.parentElement.classList.toggle('disabled', page === 0);
      nextBtn.parentElement.classList.toggle('disabled', page === total - 1);
      lastBtn.parentElement.classList.toggle('disabled', page === total - 1);

      // Scroll to top of blog list
      const section = document.querySelector('.blog-list-section');
      if (section) {
        window.scrollTo({ top: section.offsetTop - 150, behavior: 'smooth' });
      }
    }

    document.querySelectorAll('.page-btn').forEach(btn => {
      btn.addEventListener('click', () => showPage(parseInt(btn.dataset.page)));
    });
    document.querySelector('.first-btn')?.addEventListener('click', () => { if (currentPage > 0) showPage(0); });
    document.querySelector('.prev-btn')?.addEventListener('click', () => { if (currentPage > 0) showPage(currentPage - 1); });
    document.querySelector('.next-btn')?.addEventListener('click', () => { if (currentPage < total - 1) showPage(currentPage + 1); });
    document.querySelector('.last-btn')?.addEventListener('click', () => { if (currentPage < total - 1) showPage(total - 1); });
  });
</script>

<style>
  /* Blog list section layout */
  .blog-list-section section {
    max-width: 100%;
    display: flex;
  }
  @media (max-width: 940px) {
    .blog-list-section section {
      flex-direction: column;
    }
  }

  /* Content area */
  .blog-list-section .content {
    width: calc(100% - 292px);
  }
  @media (max-width: 940px) {
    .blog-list-section .content {
      width: 100%;
    }
  }

  /* Blog cards grid */
  .blogs {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    position: inherit;
    z-index: 1;
  }
  @media (max-width: 610px) {
    .blogs {
      justify-content: center;
    }
  }

  /* Individual blog card */
  .blog {
    color: #000000;
    width: 291px;
    margin-right: 25px;
    margin-bottom: 55px;
    text-align: left;
    overflow: hidden;
  }
  @media (max-width: 1100px) {
    .blog {
      width: 284px;
      margin-right: 10px;
    }
  }
  @media (max-width: 940px) {
    .blog {
      width: 291px;
      margin-right: 25px;
    }
  }
  @media (max-width: 760px) {
    .blog {
      width: 100%;
    }
  }
  @media (max-width: 610px) {
    .blog {
      width: 291px;
      margin-right: 0px;
    }
  }
  @media (max-width: 350px) {
    .blog {
      width: 284px;
    }
  }

  /* Blog card image */
  .blog-img {
    height: 320px;
    object-fit: cover;
    width: 100%;
  }
  @media (max-width: 1100px) {
    .blog-img {
      width: 284px;
    }
  }
  @media (max-width: 940px) {
    .blog-img {
      width: 291px;
    }
  }
  @media (max-width: 760px) {
    .blog-img {
      float: left;
      margin-right: 20px;
    }
  }
  @media (max-width: 610px) {
    .blog-img {
      float: none;
      margin-right: 0px;
    }
  }
  @media (max-width: 350px) {
    .blog-img {
      width: 284px;
    }
  }

  /* Blog card title */
  .blog-title {
    margin-top: 15px;
    font-family: "CaslonGraphiqueEF";
    font-size: 22px;
    line-height: 24px;
    text-align: left;
  }

  /* Blog card date */
  .blog-date {
    margin-top: 15px;
    font-family: "CaslonGraphiqueEF";
    font-size: 14px;
    line-height: 14px;
    text-align: left;
    display: flex;
    align-items: center;
  }
  .icon-calendar {
    padding-right: 10px;
    height: 14px;
    width: auto;
  }

  /* Blog card excerpt */
  .blog p {
    margin-top: 15px;
    font-family: "BentonSans", sans-serif;
    margin-bottom: 15px;
    color: #000000;
  }

  /* Read more link */
  .read-more {
    color: #20A1AA;
    font-family: "CaslonGraphiqueEF";
    font-size: 14px;
    z-index: 3;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .icon-more {
    padding-left: 18px;
    height: 12px;
    width: auto;
  }

  /* Pagination */
  :global(.pagination ul) {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  :global(.pagination ul li) {
    width: 34px;
    height: 34px;
    border: 3px solid #000000;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 5px;
    cursor: pointer;
  }
  :global(.pagination ul li.active) {
    border-color: #20A1AA;
    background-color: #20A1AA;
    color: #ffffff;
  }
  :global(.pagination ul li.disabled) {
    display: none;
  }
  :global(.pagination ul li a) {
    font-size: 14px;
    font-family: "BentonSans", sans-serif;
    font-weight: 700;
    user-select: none;
  }

  /* Sidebar */
  .sidebar {
    float: right;
  }
  @media (max-width: 940px) {
    .sidebar {
      width: 100%;
      display: flex;
      justify-content: space-between;
      margin-top: 30px;
    }
  }
  @media (max-width: 760px) {
    .sidebar {
      flex-direction: column;
      align-items: center;
    }
  }

  /* Archive */
  .archive {
    width: 291px;
    background-color: #F4F4F4;
    padding: 20px;
    position: relative;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 24px;
    color: #282828;
  }
  @media (max-width: 940px) {
    .archive {
      margin-top: 0px;
    }
  }
  @media (max-width: 760px) {
    .archive {
      margin-top: 40px;
      margin-bottom: 40px;
      width: 100%;
    }
  }
  .archive ul {
    padding-top: 20px;
    list-style: none;
    padding-left: 0;
  }
  .archive ul li {
    position: relative;
    display: block;
    border-radius: 4px;
    height: 31px;
    background-color: #d8d8d8;
    cursor: pointer;
    margin: 5px;
    font-size: 14px;
    line-height: 31px;
    padding: 0px 13px;
  }
  .archive ul li:before {
    display: inline-block;
    content: "";
    height: 31px;
    width: 4px;
    position: absolute;
    left: 0;
    background-color: #20A1AA;
    border-radius: 4px 0px 0px 4px;
  }
  .archive ul li span {
    float: right;
  }
</style>
