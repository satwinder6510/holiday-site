    border-width: 0;
  }
  .breadcrumbs span[aria-current="page"] {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 10px;
    line-height: 12px;
    color: #ffffff;
    opacity: 0.7;
  }
  .content h3.sub-heading {
    margin-top: 40px;
    font-size: 28px;
    line-height: 32px;
  }
  @media (max-width: 768px) {
    .content h3.sub-heading {
      font-size: 24px;
      line-height: 28px;
    }
  }
  .call-expert-phone a {
    color: #ffffff;
    text-decoration: none;
  }
  .call-expert-phone a:hover {
    text-decoration: underline;
  }
  /* Focus-visible states */
  .btn-check-price:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
    box-shadow: 0 0 0 5px rgba(255, 127, 0, 0.5);
  }
  .btn-check-price-sidebar:focus-visible {
    outline: 2px solid #ff7f00;
    outline-offset: 3px;
  }
  .panel-header:focus-visible {
    outline: 2px solid #20A1AA;
    outline-offset: -2px;
    border-radius: 4px;
  }
  .img-carousel-prev:focus-visible,
  .img-carousel-next:focus-visible,
  .img-carousel-expand:focus-visible {
    outline: 2px solid #20A1AA;
    outline-offset: 2px;
  }
  .lightbox-close:focus-visible,
  .lightbox-prev:focus-visible,
  .lightbox-next:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }
  .blog-card a:focus-visible {
    outline: 2px solid #20A1AA;
    outline-offset: 2px;
  }
  /* Mobile bottom padding for fixed price bar */
  @media (max-width: 768px) {
    .blog-posts-section {
      padding-bottom: 120px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ===== ANCHOR NAV — smooth scroll + scroll-spy =====
    const tabLinks = document.querySelectorAll('.tab-list li a') as NodeListOf<HTMLAnchorElement>;
    const tabItems = document.querySelectorAll('.tab-list li');
    const sections = document.querySelectorAll('.content-section') as NodeListOf<HTMLElement>;
    const currentLabel = document.querySelector('.mobile-tab-toggle .current');

    // Smooth-scroll on click
    tabLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = link.getAttribute('href')?.slice(1);
        const target = id ? document.getElementById(id) : null;
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
        // Close mobile dropdown
        const tabList = document.querySelector('.tab-list');
        if (tabList) tabList.classList.remove('open-drop-down');
      });
    });

    // Scroll-spy: highlight active tab based on which section is in view
    function updateActiveTab() {
      let activeId = '';
      const offset = 150; // account for sticky header
      for (const section of sections) {
        const rect = section.getBoundingClientRect();
        if (rect.top <= offset) {
          activeId = section.id;
        }
      }
      if (!activeId && sections.length > 0) activeId = sections[0].id;

      tabItems.forEach(item => item.classList.remove('ui-tabs-active'));
      tabLinks.forEach(link => {
        if (link.getAttribute('href') === `#${activeId}`) {
          link.parentElement?.classList.add('ui-tabs-active');
        }
      });
      if (currentLabel) {
        const activeLink = document.querySelector('.tab-list li.ui-tabs-active a');
        if (activeLink) {
          currentLabel.textContent = activeLink.textContent;
        }
      }
    }

    window.addEventListener('scroll', updateActiveTab, { passive: true });
    updateActiveTab();

    // ===== LOCAL CHARGES =====
    const localChargesEl = document.getElementById('local-charges-data');
    const localChargesData = localChargesEl ? JSON.parse(localChargesEl.textContent || '{"ppGbp":0,"breakdown":[]}') : { ppGbp: 0, breakdown: [] };
    const localChargesPp = localChargesData.ppGbp || 0;

    // Local charges breakdown toggle
    const lcToggle = document.getElementById('local-charges-toggle');
    const lcBreakdown = document.getElementById('local-charges-breakdown');
    if (lcToggle && lcBreakdown) {
      lcToggle.addEventListener('click', () => {
        const visible = lcBreakdown.style.display !== 'none';
        lcBreakdown.style.display = visible ? 'none' : 'block';
        lcToggle.textContent = visible ? 'View breakdown' : 'Hide breakdown';
      });
    }

    // ===== DATE-WISE PRICING =====
    const pricingDataEl = document.getElementById('pricing-data');
    const pricingData = pricingDataEl ? JSON.parse(pricingDataEl.textContent || 'null') : null;

    if (pricingData) {
      // State
      let selectedAirport = pricingData.airports[0]?.code || '';
      let selectedDate = '';
      let passengerCount = 2;

      // DOM refs
      const inlineAirportSelect = document.getElementById('inline-airport-select') as HTMLSelectElement | null;
      const inlineDateCards = document.getElementById('inline-date-cards');
      const btnViewAllDates = document.getElementById('btn-view-all-dates');
      const btnCheckPrice = document.getElementById('btn-check-price');
      const btnCheckPriceSidebar = document.getElementById('btn-check-price-sidebar');
      const btnMobilePricing = document.getElementById('btn-mobile-pricing');
      const modalEl = document.getElementById('pricing-modal');
      const modalClose = document.getElementById('pricing-modal-close');
      const modalAirportSelect = document.getElementById('modal-airport-select') as HTMLSelectElement | null;
      const modalPaxSelect = document.getElementById('modal-pax-select') as HTMLSelectElement | null;
      const calendarGrid = document.getElementById('pricing-calendar-grid');
      const modalSummaryInfo = document.getElementById('modal-summary-info');
      const modalBookBtn = document.getElementById('modal-book-btn') as HTMLButtonElement | null;
      const heroPriceLabel = document.getElementById('hero-price-label');
      const heroPriceValue = document.getElementById('hero-price-value');
      const sidebarPriceLabel = document.getElementById('sidebar-price-label');
      const sidebarPriceValue = document.getElementById('sidebar-price-value');
      const mobilePriceBar = document.getElementById('mobile-price-bar');
      const mobilePriceLabel = document.getElementById('mobile-price-label');
      const mobilePriceValue = document.getElementById('mobile-price-value');

      // Helpers
      const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      const DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const MONTHS_SHORT = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

      function formatPrice(p: number): string {
        return '\u00A3' + Math.round(p).toLocaleString('en-GB');
      }

      function getDepsForAirport(code: string) {
        return pricingData.departures.filter((d: any) => d.airportCode === code);
      }

      function getCheapestForAirport(code: string): number {
        const deps = getDepsForAirport(code);
        if (deps.length === 0) return 0;
        return Math.min(...deps.map((d: any) => d.pricePp)) + localChargesPp;
      }

      // Render inline date cards
      function renderDateCards() {
        if (!inlineDateCards) return;
        const deps = getDepsForAirport(selectedAirport).slice(0, 4);
        inlineDateCards.innerHTML = deps.map((dep: any, i: number) => `
          <button type="button" class="pricing-card pricing-card--${dep.tier}${dep.date === selectedDate ? ' pricing-card--selected' : ''}" data-date="${dep.date}" data-airport="${dep.airportCode}" data-price="${dep.pricePp + localChargesPp}">
            ${i === 0 ? '<span class="pricing-card__badge">Best Price</span>' : ''}
            <span class="pricing-card__day">${dep.dayOfWeek}</span>
            <span class="pricing-card__date">${dep.dateShort}</span>
            <span class="pricing-card__price">${formatPrice(dep.pricePp + localChargesPp)}<small>/pp</small></span>
          </button>
        `).join('');

        // Attach click handlers
        inlineDateCards.querySelectorAll('.pricing-card').forEach(card => {
          card.addEventListener('click', () => {
            const date = (card as HTMLElement).dataset.date || '';
            handleDateSelect(date);
          });
        });
      }

      // Calendar month navigation state
      let calMonthKeys: string[] = [];
      let calMonthIndex = 0;
      const monthLabel = document.getElementById('month-label');
      const monthPrevBtn = document.getElementById('month-prev') as HTMLButtonElement | null;
      const monthNextBtn = document.getElementById('month-next') as HTMLButtonElement | null;

      // Build sorted month keys from current airport departures
      function buildMonthKeys() {
        const deps = getDepsForAirport(selectedAirport);
        const keySet = new Set<string>();
        for (const dep of deps) {
          const d = new Date(dep.date + 'T00:00:00');
          keySet.add(`${d.getFullYear()}-${String(d.getMonth()).padStart(2, '0')}`);
        }
        calMonthKeys = Array.from(keySet).sort();
        calMonthIndex = 0;
      }

      // Render a single month grid
      function renderCalendarMonth() {
        if (!calendarGrid || calMonthKeys.length === 0) {
          if (calendarGrid) calendarGrid.innerHTML = '<p style="text-align:center;color:#666;padding:24px;">No departures for this airport.</p>';
          if (monthLabel) monthLabel.textContent = '';
          return;
        }

        const monthKey = calMonthKeys[calMonthIndex];
        const [year, mon] = monthKey.split('-').map(Number);
        const deps = getDepsForAirport(selectedAirport);

        // Build lookup for this month
        const depsMap = new Map<number, any>();
        for (const dep of deps) {
          const d = new Date(dep.date + 'T00:00:00');
          if (d.getFullYear() === year && d.getMonth() === mon) {
            depsMap.set(d.getDate(), dep);
          }
        }

        // Update month label with position indicator
        if (monthLabel) {
          monthLabel.innerHTML = `${MONTHS[mon]} ${year}<span class="month-position">${calMonthIndex + 1} of ${calMonthKeys.length}</span>`;
        }

        // Update arrow states
        if (monthPrevBtn) monthPrevBtn.disabled = calMonthIndex === 0;
        if (monthNextBtn) monthNextBtn.disabled = calMonthIndex === calMonthKeys.length - 1;

        const firstDay = new Date(year, mon, 1).getDay();
        const daysInMonth = new Date(year, mon + 1, 0).getDate();

        let html = '<div class="cal-month"><div class="cal-month__grid">';

        // Day headers
        for (const dh of DAYS_SHORT) {
          html += `<div class="cal-day-header">${dh}</div>`;
        }

        // Empty cells for offset
        for (let i = 0; i < firstDay; i++) {
          html += '<div class="cal-day"></div>';
        }

        // Day cells
        for (let day = 1; day <= daysInMonth; day++) {
          const dep = depsMap.get(day);
          if (dep) {
            const isSelected = dep.date === selectedDate;
            html += `<button type="button" class="cal-day cal-day--available cal-day--${dep.tier}${isSelected ? ' cal-day--selected' : ''}" data-date="${dep.date}" data-price="${dep.pricePp + localChargesPp}">`;
            html += `<span class="cal-day__num">${day}</span>`;
            html += `<span class="cal-day__price">${formatPrice(dep.pricePp + localChargesPp)}</span>`;
            html += `</button>`;
          } else {
            html += `<div class="cal-day"><span class="cal-day__num">${day}</span></div>`;
          }
        }

        html += '</div></div>';
        calendarGrid.innerHTML = html;

        // Attach click handlers
        calendarGrid.querySelectorAll('.cal-day--available').forEach(cell => {
          cell.addEventListener('click', () => {
            const date = (cell as HTMLElement).dataset.date || '';
            handleDateSelect(date);
          });
        });
      }

      // Full calendar rebuild (called on airport change / modal open)
      function renderCalendar() {
        buildMonthKeys();
        // If a date is selected, jump to that month
        if (selectedDate) {
          const d = new Date(selectedDate + 'T00:00:00');
          const targetKey = `${d.getFullYear()}-${String(d.getMonth()).padStart(2, '0')}`;
          const idx = calMonthKeys.indexOf(targetKey);
          if (idx >= 0) calMonthIndex = idx;
        }
        renderCalendarMonth();
      }

      // Month nav events
      monthPrevBtn?.addEventListener('click', () => {
        if (calMonthIndex > 0) { calMonthIndex--; renderCalendarMonth(); }
      });
      monthNextBtn?.addEventListener('click', () => {
        if (calMonthIndex < calMonthKeys.length - 1) { calMonthIndex++; renderCalendarMonth(); }
      });

      // Update sidebar
      function updateSidebar() {
        if (selectedDate) {
          const dep = pricingData.departures.find((d: any) => d.date === selectedDate && d.airportCode === selectedAirport);
          if (dep) {
            const inclusivePrice = formatPrice(dep.pricePp + localChargesPp);
            if (sidebarPriceLabel) sidebarPriceLabel.textContent = '';
            if (sidebarPriceValue) sidebarPriceValue.textContent = inclusivePrice;
            if (heroPriceLabel) heroPriceLabel.textContent = '';
            if (heroPriceValue) heroPriceValue.innerHTML = inclusivePrice + '<span class="price-pp">/pp</span>';
          }
        } else {
          const cheapest = getCheapestForAirport(selectedAirport);
          if (sidebarPriceLabel) sidebarPriceLabel.textContent = 'from';
          if (sidebarPriceValue) sidebarPriceValue.textContent = formatPrice(cheapest);
          if (heroPriceLabel) heroPriceLabel.textContent = 'from';
          if (heroPriceValue) heroPriceValue.innerHTML = formatPrice(cheapest) + '<span class="price-pp">/pp</span>';
        }
      }

      // Update mobile bar
      function updateMobileBar() {
        if (!mobilePriceBar) return;
        if (selectedDate) {
          const dep = pricingData.departures.find((d: any) => d.date === selectedDate && d.airportCode === selectedAirport);
          if (dep) {
            if (mobilePriceLabel) mobilePriceLabel.textContent = '';
            if (mobilePriceValue) mobilePriceValue.innerHTML = formatPrice(dep.pricePp + localChargesPp) + '<small>/pp</small>';
          }
        } else {
          const cheapest = getCheapestForAirport(selectedAirport);
          if (mobilePriceLabel) mobilePriceLabel.textContent = 'from';
          if (mobilePriceValue) mobilePriceValue.innerHTML = formatPrice(cheapest) + '<small>/pp</small>';
        }
      }

      // Update modal summary
      function updateModalSummary() {
        if (!modalSummaryInfo || !modalBookBtn) return;
        if (selectedDate) {
          const dep = pricingData.departures.find((d: any) => d.date === selectedDate && d.airportCode === selectedAirport);
          if (dep) {
            const ppInclusive = dep.pricePp + localChargesPp;
            const total = ppInclusive * passengerCount;
            let html = `<strong>${dep.dateFormatted}</strong> from <strong>${dep.airportName}</strong><br>`;
            if (localChargesPp > 0) {
              const pkgTotal = dep.pricePp * passengerCount;
              const lcTotal = localChargesPp * passengerCount;
              html += `Package: ${passengerCount} &times; ${formatPrice(dep.pricePp)} = ${formatPrice(pkgTotal)}<br>`;
              html += `Local charges: ${passengerCount} &times; ${formatPrice(localChargesPp)} = ${formatPrice(lcTotal)}<br>`;
              html += `<strong>Total: ${formatPrice(total)}</strong>`;
            } else {
              html += `${passengerCount} passenger${passengerCount > 1 ? 's' : ''} &times; ${formatPrice(ppInclusive)} = <strong>${formatPrice(total)}</strong> total`;
            }
            modalSummaryInfo.innerHTML = html;
            modalBookBtn.disabled = false;
            modalBookBtn.textContent = 'Request Booking';
          }
        } else {
          modalSummaryInfo.textContent = 'Select a date to see pricing';
          modalBookBtn.disabled = true;
          modalBookBtn.textContent = 'Select a Date';
        }
      }

      // Handle airport change — preserve selected date if available for new airport
      function handleAirportChange(code: string) {
        selectedAirport = code;
        // Check if current selected date exists for new airport
        if (selectedDate) {
          const newDeps = getDepsForAirport(code);
          const dateStillAvailable = newDeps.some(d => d.date === selectedDate);
          if (!dateStillAvailable) selectedDate = '';
        }
        // Sync both dropdowns
        if (inlineAirportSelect) inlineAirportSelect.value = code;
        if (modalAirportSelect) modalAirportSelect.value = code;
        renderDateCards();
        renderCalendar();
        updateSidebar();
        updateMobileBar();
        updateModalSummary();
      }

      // Handle date select (no toggle-off: once selected, stays selected)
      function handleDateSelect(dateStr: string) {
        if (dateStr === selectedDate) return;
        selectedDate = dateStr;
        renderDateCards();
        renderCalendar();
        updateSidebar();
        updateMobileBar();
        updateModalSummary();
      }

      // Focus trap for modal (one-time setup)
      if (modalEl) {
        modalEl.addEventListener('keydown', (e) => {
          if (e.key !== 'Tab') return;
          const focusable = modalEl.querySelectorAll(
            'button:not([disabled]), select, [tabindex]:not([tabindex="-1"])'
          ) as NodeListOf<HTMLElement>;
          if (focusable.length === 0) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey) {
            if (document.activeElement === first) { e.preventDefault(); last.focus(); }
          } else {
            if (document.activeElement === last) { e.preventDefault(); first.focus(); }
          }
        });
      }

      // Track which element opened the modal for focus restore
      let modalTriggerEl: HTMLElement | null = null;

      // Open / close modal
      function openPricingModal() {
        if (!modalEl) return;
        modalTriggerEl = document.activeElement as HTMLElement | null;
        renderCalendar();
        updateModalSummary();
        modalEl.classList.add('visible');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            modalEl.classList.add('active');
          });
        });
        document.body.style.overflow = 'hidden';
        const closeBtn = modalEl.querySelector('.pricing-modal__close') as HTMLElement;
        closeBtn?.focus();
      }

      function closePricingModal() {
        if (!modalEl) return;
        modalEl.classList.remove('active');
        setTimeout(() => {
          modalEl.classList.remove('visible');
          document.body.style.overflow = '';
        }, 250);
        // Restore focus to the element that opened the modal
        if (modalTriggerEl && typeof modalTriggerEl.focus === 'function') {
          modalTriggerEl.focus();
          modalTriggerEl = null;
        }
      }

      // Event listeners
      inlineAirportSelect?.addEventListener('change', () => handleAirportChange(inlineAirportSelect.value));
      modalAirportSelect?.addEventListener('change', () => handleAirportChange(modalAirportSelect.value));
      modalPaxSelect?.addEventListener('change', () => {
        passengerCount = parseInt(modalPaxSelect.value, 10);
        updateModalSummary();
      });

      btnViewAllDates?.addEventListener('click', openPricingModal);
      btnCheckPrice?.addEventListener('click', (e) => { e.preventDefault(); openPricingModal(); });
      btnCheckPriceSidebar?.addEventListener('click', (e) => { e.preventDefault(); openPricingModal(); });
      btnMobilePricing?.addEventListener('click', openPricingModal);
      modalClose?.addEventListener('click', closePricingModal);

      // Book button → open enquiry modal with selected details
      modalBookBtn?.addEventListener('click', () => {
        if (!selectedDate || modalBookBtn.disabled) return;
        const dep = pricingData.departures.find((d: any) => d.date === selectedDate && d.airportCode === selectedAirport);
        if (dep) {
          openEnquiryModal({
            date: dep.dateFormatted,
            airport: dep.airportName,
            adults: String(passengerCount),
          });
          closePricingModal();
        }
      });

      // Close on overlay click
      modalEl?.addEventListener('click', (e) => {
        if (e.target === modalEl) closePricingModal();
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modalEl?.classList.contains('active')) closePricingModal();
      });
    }

    // ===== ACCORDION =====
    const panelHeaders = document.querySelectorAll('.panel-header');
    panelHeaders.forEach(header => {
      const togglePanel = () => {
        const panelContent = header.nextElementSibling as HTMLElement | null;
        const icon = header.querySelector('.panel-icon');
        if (!panelContent || !icon) return;

        if (panelContent.style.display === 'none' || panelContent.style.display === '') {
          panelContent.style.display = 'block';
          icon.classList.remove('icon-more-plus');
          icon.classList.add('icon-less-minus');
          header.setAttribute('aria-expanded', 'true');
        } else {
          panelContent.style.display = 'none';
          icon.classList.remove('icon-less-minus');
          icon.classList.add('icon-more-plus');
          header.setAttribute('aria-expanded', 'false');
        }
      };
      header.addEventListener('click', togglePanel);
      header.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          togglePanel();
        }
      });
    });

    // ===== MOBILE TAB DROPDOWN =====
    const dropDown = document.querySelector('.mobile-tab-toggle .drop-down');
    const tabList = document.querySelector('.tab-list');
    if (dropDown && tabList) {
      dropDown.addEventListener('click', () => {
        tabList.classList.toggle('open-drop-down');
      });
      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!dropDown.contains(e.target as Node) && !tabList.contains(e.target as Node)) {
          tabList.classList.remove('open-drop-down');
        }
      });
    }

    // ===== MOBILE SUMMARY BUTTON =====
    const summaryBtn = document.querySelector('.summary-btn');
    const sidebar = document.getElementById('summary');
    const mainContent = document.getElementById('main-content');
    if (summaryBtn && sidebar && mainContent) {
      summaryBtn.addEventListener('click', () => {
        const isOpen = sidebar.classList.contains('open-summary');
        if (isOpen) {
          sidebar.classList.remove('open-summary');
          mainContent.classList.remove('close');
          summaryBtn.classList.remove('close');
          summaryBtn.textContent = 'Summary';
        } else {
          sidebar.classList.add('open-summary');
          mainContent.classList.add('close');
          summaryBtn.classList.add('close');
          summaryBtn.textContent = 'Close';
        }
      });
    }

    // ===== STICKY HEADER =====
    const tabNav = document.getElementById('tab_navigation');
    if (tabNav) {
      const tabNavTop = tabNav.offsetTop;
      window.addEventListener('scroll', () => {
        if (window.scrollY >= tabNavTop) {
          tabNav.classList.add('stick');
        } else {
          tabNav.classList.remove('stick');
        }
      });
    }

    // ===== IMAGE CAROUSELS (Accommodation + Gallery) =====
    document.querySelectorAll('.img-carousel').forEach((carousel) => {
      const slides = carousel.querySelectorAll('.img-carousel-slide') as NodeListOf<HTMLImageElement>;
      const counter = carousel.querySelector('.img-carousel-counter');
      const total = slides.length;
      let idx = 0;

      function show(newIdx: number) {
        slides[idx].classList.remove('active');
        idx = (newIdx + total) % total;
        slides[idx].classList.add('active');
        if (counter) counter.textContent = `${idx + 1} / ${total}`;
      }

      carousel.querySelector('.img-carousel-prev')?.addEventListener('click', () => show(idx - 1));
      carousel.querySelector('.img-carousel-next')?.addEventListener('click', () => show(idx + 1));

      // Expand button opens lightbox with this carousel's images
      carousel.querySelector('.img-carousel-expand')?.addEventListener('click', () => {
        const srcs = Array.from(slides).map(s => s.src);
        openLightbox(srcs, idx);
      });
    });

    // ===== LIGHTBOX =====
    const lightbox = document.getElementById('gallery-lightbox');
    const lightboxImg = lightbox?.querySelector('.lightbox-img') as HTMLImageElement;
    const lightboxCounter = lightbox?.querySelector('.lightbox-counter');
    let lbImages: string[] = [];
    let lbIndex = 0;

    function openLightbox(images: string[], index: number) {
      if (!lightbox || !lightboxImg || !lightboxCounter) return;
      lbImages = images;
      lbIndex = index;
      lightboxImg.src = lbImages[lbIndex];
      lightboxImg.alt = `Image ${lbIndex + 1} of ${lbImages.length}`;
      lightboxCounter.textContent = `${lbIndex + 1} / ${lbImages.length}`;
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    }

    function lbPrev() {
      lbIndex = (lbIndex - 1 + lbImages.length) % lbImages.length;
      openLightbox(lbImages, lbIndex);
    }

    function lbNext() {
      lbIndex = (lbIndex + 1) % lbImages.length;
      openLightbox(lbImages, lbIndex);
    }

    lightbox?.querySelector('.lightbox-close')?.addEventListener('click', closeLightbox);
    lightbox?.querySelector('.lightbox-overlay')?.addEventListener('click', closeLightbox);
    lightbox?.querySelector('.lightbox-prev')?.addEventListener('click', lbPrev);
    lightbox?.querySelector('.lightbox-next')?.addEventListener('click', lbNext);

    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') lbPrev();
      if (e.key === 'ArrowRight') lbNext();
    });

    // ===== ENQUIRY MODAL =====
    const holidayMetaEl = document.getElementById('holiday-meta');
    const holidayMeta = holidayMetaEl ? JSON.parse(holidayMetaEl.textContent || '{}') : {};

    const enquiryModal = document.getElementById('enquiry-modal');
    const enquiryClose = document.getElementById('enquiry-modal-close');
    const enquiryForm = document.getElementById('enquiry-form') as HTMLFormElement | null;
    const enquirySubmitBtn = document.getElementById('enquiry-submit-btn') as HTMLButtonElement | null;
    const enquiryDetails = document.getElementById('enquiry-selected-details');
    let enquiryTriggerEl: HTMLElement | null = null;
    let enquiryExtra: Record<string, string> = {};

    function openEnquiryModal(details?: { date?: string; airport?: string; adults?: string }) {
      if (!enquiryModal) return;
      enquiryTriggerEl = document.activeElement as HTMLElement | null;
      enquiryExtra = {};

      if (details && enquiryDetails) {
        const parts: string[] = [];
        if (details.date) { parts.push(details.date); enquiryExtra.departure_date = details.date; }
        if (details.airport) { parts.push('from ' + details.airport); }
        if (details.adults) { parts.push(details.adults + ' passenger' + (details.adults !== '1' ? 's' : '')); enquiryExtra.num_adults = details.adults; }
        enquiryDetails.textContent = parts.join(' \u2022 ');
        enquiryDetails.style.display = parts.length ? '' : 'none';
      } else if (enquiryDetails) {
        enquiryDetails.style.display = 'none';
      }

      enquiryModal.classList.add('visible');
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          enquiryModal.classList.add('active');
        });
      });
      document.body.style.overflow = 'hidden';
      (enquiryModal.querySelector('#enq-first-name') as HTMLElement)?.focus();
    }

    function closeEnquiryModal() {
      if (!enquiryModal) return;
      enquiryModal.classList.remove('active');
      setTimeout(() => {
        enquiryModal.classList.remove('visible');
        document.body.style.overflow = '';
      }, 250);
      if (enquiryTriggerEl && typeof enquiryTriggerEl.focus === 'function') {
        enquiryTriggerEl.focus();
        enquiryTriggerEl = null;
      }
    }

    // Expose openEnquiryModal globally so pricing modal JS can call it
    (window as any).__openEnquiryModal = openEnquiryModal;

    enquiryClose?.addEventListener('click', closeEnquiryModal);
    enquiryModal?.addEventListener('click', (e) => {
      if (e.target === enquiryModal) closeEnquiryModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && enquiryModal?.classList.contains('active')) closeEnquiryModal();
    });

    // Focus trap
    if (enquiryModal) {
      enquiryModal.addEventListener('keydown', (e) => {
        if (e.key !== 'Tab') return;
        const focusable = enquiryModal.querySelectorAll(
          'input:not([disabled]), button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        ) as NodeListOf<HTMLElement>;
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      });
    }

    // Form submit
    enquiryForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!enquirySubmitBtn) return;
      // Validate required fields
      if (!enquiryForm.checkValidity()) {
        enquiryForm.reportValidity();
        return;
      }
      const data = new FormData(enquiryForm);
      const payload: Record<string, string> = {};
      data.forEach((val, key) => { payload[key] = val as string; });

      payload.form_type = 'Package Enquiry';
      payload.package_name = holidayMeta.title || '';
      payload.package_id = String(holidayMeta.id || '');
      payload.source = sessionStorage.getItem('lead_source') || 'Direct';
      payload.landing_page = sessionStorage.getItem('landing_page') || '';
      payload.page_url = window.location.pathname;

      // Merge date/adults from pricing selection
      if (enquiryExtra.departure_date) payload.departure_date = enquiryExtra.departure_date;
      if (enquiryExtra.num_adults) payload.num_adults = enquiryExtra.num_adults;

      enquirySubmitBtn.disabled = true;
      enquirySubmitBtn.textContent = 'Sending...';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          // Hide form + summary, show success
          const summary = document.getElementById('enquiry-summary');
          const success = document.getElementById('enquiry-success');
          if (enquiryForm) enquiryForm.style.display = 'none';
          if (summary) summary.style.display = 'none';
          if (success) success.style.display = '';
          setTimeout(() => {
            closeEnquiryModal();
            // Reset for next use
            if (enquiryForm) { enquiryForm.reset(); enquiryForm.style.display = ''; }
            if (summary) summary.style.display = '';
            if (success) success.style.display = 'none';
            enquirySubmitBtn.textContent = 'Submit Enquiry';
            enquirySubmitBtn.disabled = false;
          }, 10000);
        } else {
          enquirySubmitBtn.textContent = 'Submit Enquiry';
          enquirySubmitBtn.disabled = false;
          alert('Sorry, there was a problem submitting your enquiry. Please call us on 0208 183 0518.');
        }
      } catch {
        enquirySubmitBtn.textContent = 'Submit Enquiry';
        enquirySubmitBtn.disabled = false;
        alert('Sorry, there was a problem submitting your enquiry. Please call us on 0208 183 0518.');
      }
    });

    // For non-pricing holidays, "Check Price & Book" opens the enquiry form directly
    if (!pricingData) {
      const btnCheckPrice = document.getElementById('btn-check-price');
      const btnCheckPriceSidebar = document.getElementById('btn-check-price-sidebar');
      btnCheckPrice?.addEventListener('click', (e) => { e.preventDefault(); openEnquiryModal(); });
      btnCheckPriceSidebar?.addEventListener('click', (e) => { e.preventDefault(); openEnquiryModal(); });
    }

    // "Request A Call Back" → open enquiry modal
    const callBackBtn = document.querySelector('.call-expert-btn') as HTMLElement | null;
    if (callBackBtn) {
      callBackBtn.addEventListener('click', (e) => {
        e.preventDefault();
        openEnquiryModal();
      });
    }
  });
</script>
