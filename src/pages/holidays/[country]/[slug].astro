     ======================================== */
  .img-carousel {
    position: relative;
    margin-top: 20px;
    margin-bottom: 20px;
    border-radius: 4px;
    overflow: hidden;
    background: #f0f0f0;
  }
  .img-carousel-viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
  }
  .img-carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }
  .img-carousel-slide.active {
    display: block;
  }
  .img-carousel-prev,
  .img-carousel-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: rgba(255, 255, 255, 0.85);
    border: none;
    color: #424242;
    font-size: 20px;
    cursor: pointer;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }
  .img-carousel-prev:hover,
  .img-carousel-next:hover {
    background: #ffffff;
  }
  .img-carousel-prev { left: 12px; }
  .img-carousel-next { right: 12px; }
  @media (max-width: 530px) {
    .img-carousel-prev,
    .img-carousel-next {
      width: 36px;
      height: 36px;
      font-size: 16px;
    }
    .img-carousel-prev { left: 8px; }
    .img-carousel-next { right: 8px; }
  }
  .img-carousel-expand {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    width: 36px;
    height: 36px;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .img-carousel-expand:hover {
    background: rgba(0, 0, 0, 0.7);
  }
  .img-carousel-expand img {
    width: 18px;
    height: 18px;
    filter: brightness(0) invert(1);
  }
  .img-carousel-counter {
    position: absolute;
    bottom: 12px;
    left: 12px;
    z-index: 2;
    background: rgba(0, 0, 0, 0.5);
    color: #ffffff;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 13px;
