---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import MobileNav from '../../../components/MobileNav.astro';
import Footer from '../../../components/Footer.astro';
import Newsletter from '../../../components/Newsletter.astro';
import MobileCallCTA from '../../../components/MobileCallCTA.astro';
import BreadcrumbSchema from '../../../components/BreadcrumbSchema.astro';
import type { HolidayDetail } from '../../../lib/holiday-transforms';
import { allBlogs } from '../../../data/blogs';
import { getDb } from '../../../lib/get-db';
import { getHolidayBySlugFromDb } from '../../../lib/holidays-db';

const { slug } = Astro.params;

let holiday: HolidayDetail;
let pricing: any;
let hasPricing: boolean;
try {
  const db = getDb(Astro);
  const result = await getHolidayBySlugFromDb(db, slug!);
  if (!result) {
    return new Response(null, { status: 404, statusText: 'Not Found' });
  }
  holiday = result.holiday;
  pricing = result.pricing;
  hasPricing = !!pricing;
} catch (e) {
  console.error('DB error on holiday detail:', e);
  return new Response('Service temporarily unavailable', { status: 503 });
}

const countryLower = holiday.country.toLowerCase();
const matchedBlogs = allBlogs.filter(b => {
  const text = (b.title + ' ' + b.excerpt).toLowerCase();
  return text.includes(countryLower);
});
const latestBlogs = matchedBlogs.length >= 2 ? matchedBlogs.slice(0, 4) : allBlogs.slice(0, 4);

const pricingJson = hasPricing ? JSON.stringify(pricing) : 'null';

const localCharges = holiday.localChargesPp;
const displayPrice = holiday.price + localCharges;
const localChargesJson = JSON.stringify({ ppGbp: localCharges, breakdown: holiday.localChargesBreakdown });

function fmtPrice(p: number): string {
  return '\u00A3' + Math.round(p).toLocaleString('en-GB');
}
const displayPriceFormatted = fmtPrice(displayPrice);
const cheapestInclusive = hasPricing ? fmtPrice(pricing!.cheapestPrice + localCharges) : displayPriceFormatted;
const airportPrices = hasPricing ? pricing!.airports.map((ap: any) => ({
  ...ap,
  inclusiveFormatted: fmtPrice(ap.cheapestPrice + localCharges),
})) : [];
const initialDeps = hasPricing ? pricing!.departures
  .filter((d: any) => d.airportCode === pricing!.airports[0].code)
  .slice(0, 4)
  .map((dep: any) => ({
    ...dep,
    inclusivePrice: dep.pricePp + localCharges,
    inclusiveFormatted: fmtPrice(dep.pricePp + localCharges),
  })) : [];

// Truncate description at sentence boundary
const rawDesc = holiday.overview || holiday.description || '';
let productDesc = rawDesc;
if (productDesc.length > 300) {
  const truncated = productDesc.substring(0, 300);
  const lastSentence = truncated.lastIndexOf('.');
  productDesc = lastSentence > 100 ? truncated.substring(0, lastSentence + 1) : truncated;
}

const productImages = [holiday.heroImage, ...holiday.galleryImages.slice(0, 4)].filter(Boolean);

const productSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: holiday.title,
  description: productDesc,
  image: productImages.length > 1 ? productImages : holiday.heroImage,
  brand: { '@type': 'Organization', name: 'Flights and Packages' },
  sku: `FP-${holiday.id}`,
  category: 'Holiday Package',
};
if (hasPricing) {
  const highPrice = Math.max(...pricing!.departures.map((d: any) => d.pricePp)) + localCharges;
  productSchema.offers = {
    '@type': 'AggregateOffer',
    priceCurrency: 'GBP',
    lowPrice: pricing!.cheapestPrice + localCharges,
    highPrice,
    offerCount: pricing!.departures.length,
    availability: 'https://schema.org/InStock',
    url: `https://holidays.flightsandpackages.com/Holidays/${holiday.countrySlug}/${holiday.slug}`,
    offeredBy: { '@type': 'Organization', name: 'Flights and Packages' },
  };
} else {
  productSchema.offers = {
    '@type': 'Offer',
    priceCurrency: 'GBP',
    price: displayPrice,
    availability: 'https://schema.org/InStock',
    url: `https://holidays.flightsandpackages.com/Holidays/${holiday.countrySlug}/${holiday.slug}`,
    offeredBy: { '@type': 'Organization', name: 'Flights and Packages' },
  };
}

// Build page description: prefer meta description, fall back to structured summary
const pageDescription = holiday.metaDescription || (() => {
  const parts: string[] = [`Book ${holiday.title}`];
  if (displayPrice) parts.push(`from ${displayPriceFormatted}pp`);
  if (holiday.duration) parts.push(`${holiday.duration} in ${holiday.destination || holiday.country}`);
  if (holiday.boardBasis) parts.push(holiday.boardBasis);
  parts.push('Flights included. ATOL protected.');
  return parts.join('. ');
})();
---

<BaseLayout title={holiday.metaTitle || `${holiday.title} | Holidays - Flights and Packages`} description={pageDescription} image={holiday.heroImage} type="product">
  <BreadcrumbSchema slot="head" items={[
    { name: 'Home', url: '/' },
    { name: 'Destinations', url: '/destinations' },
    { name: holiday.country, url: `/Holidays/${holiday.countrySlug}` },
    { name: holiday.title },
  ]} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <Header />
  <MobileNav />

  <!-- Hero Section -->
  <section class="itinerary-hero">
    <div class="hero-bg" style={`background-image: url('${holiday.heroImage}')`}></div>
    <div class="breadcrumbs">
      <a href="/">Home</a>
      <span class="icon-breadcrumb"></span>
      <a href="/destinations">Destinations</a>
      <span class="icon-breadcrumb"></span>
      <a href={`/Holidays/${holiday.countrySlug}`}>{holiday.country}</a>
      <span class="icon-breadcrumb"></span>
      <span aria-current="page">{holiday.title}</span>
    </div>
    <div class="hero-content">
      <div class="hero-label">discover</div>
      <h1>{holiday.title}</h1>
    </div>
  </section>

  <!-- Search / Price Bar -->
  <section class="search-section">
    <div class={`search-form section-container ${hasPricing ? 'has-pricing' : ''}`}>
      <div class="form-box">
        <p class="form-p-title">{holiday.title}</p>
        <p class="para2">{holiday.destination} &bull; {holiday.duration} &bull; {holiday.boardBasis}</p>
      </div>
      <div class="price-area">
        <div class="price-wrap">
          <span class="price-from" id="hero-price-label">from</span>
          <div class="price-amount" id="hero-price-value">{cheapestInclusive}<span class="price-pp">/pp</span></div>
        </div>
        <a href="#" class="btn-check-price" id="btn-check-price">{hasPricing ? 'Check Dates & Prices' : 'Check Price & Book'}<img src="/icons/more-icon-white.svg" alt="" class="icon-more" /></a>
      </div>
    </div>
  </section>

  <!-- Local Charges Info -->
  {localCharges > 0 && (
    <section class="local-charges-bar">
      <div class="local-charges-bar__inner section-container">
        <div class="local-charges-bar__summary">
          <span class="local-charges-bar__icon">&#9432;</span>
          Price includes &pound;{Math.round(localCharges)}/pp local charges, payable at accommodation
        </div>
        <button type="button" class="local-charges-bar__toggle" id="local-charges-toggle">View breakdown</button>
      </div>
      <div class="local-charges-bar__breakdown" id="local-charges-breakdown" style="display:none;">
        <div class="section-container">
          <div class="local-charges-list">
            {holiday.localChargesBreakdown.map((item: any) => (
              <div class="local-charges-list__row">
                <span class="local-charges-list__label">{item.label}</span>
                <span class="local-charges-list__foreign">{item.currency} {item.foreignAmount.toFixed(2)}</span>
                <span class="local-charges-list__rate">Rate: {item.exchangeRate}</span>
                <span class="local-charges-list__gbp">&pound;{item.gbpAmount.toFixed(2)}</span>
              </div>
            ))}
            <div class="local-charges-list__total">
              <span>Total per person</span>
              <span>&pound;{localCharges.toFixed(2)}</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Inline Pricing Section -->
  {hasPricing && (
    <section class="pricing-inline">
      <div class="pricing-inline__inner section-container">
        <div class="pricing-inline__controls">
          <label class="pricing-inline__label" for="inline-airport-select">Departing from</label>
          <select class="pricing-inline__select" id="inline-airport-select">
            {airportPrices.map((ap: any) => (
              <option value={ap.code}>{ap.name} — from {ap.inclusiveFormatted}/pp</option>
            ))}
          </select>
        </div>
        <div class="pricing-inline__cards" id="inline-date-cards">
          {initialDeps.map((dep: any, i: number) => (
              <button type="button" class={`pricing-card pricing-card--${dep.tier}`} data-date={dep.date} data-airport={dep.airportCode} data-price={dep.inclusivePrice}>
                {i === 0 && <span class="pricing-card__badge">Best Price</span>}
                <span class="pricing-card__day">{dep.dayOfWeek}</span>
                <span class="pricing-card__date">{dep.dateShort}</span>
                <span class="pricing-card__price">{dep.inclusiveFormatted}<small>/pp</small></span>
              </button>
            ))}
        </div>
        <button type="button" class="pricing-inline__view-all" id="btn-view-all-dates">
          View All Dates &amp; Prices <img src="/icons/more-icon.svg" alt="" class="icon-more-teal" />
        </button>
      </div>
    </section>
  )}

  <!-- Tab Navigation -->
  <div class="tabs" id="tabs-container">
    <div id="tab_navigation" class="itinerary-header">
      <div class="section-container header-inner">
        <div class="mobile-tab-toggle">
          <div class="drop-down">
            <span class="current">Overview</span>
            <span class="icon-sort-by"></span>
          </div>
          <button class="btn-summary summary-btn">Summary</button>
        </div>
        <ul class="tab-list">
          <li class="ui-tabs-active"><a href="#overview">Overview</a></li>
          {holiday.accommodations.length > 0 && (
            <li><a href="#accommodation">Accommodation</a></li>
          )}
          {holiday.itinerary.length > 0 && (
            <li><a href="#itinerary">Itinerary</a></li>
          )}
          {holiday.review && (
            <li><a href="#reviews">Reviews</a></li>
          )}
          {holiday.galleryImages.length > 0 && (
            <li><a href="#gallery">Gallery</a></li>
          )}
          {(holiday.otherInfo || holiday.otherInfoBullets.length > 0) && (
            <li><a href="#otherinfo">More Info</a></li>
          )}
        </ul>
      </div>
    </div>

    <!-- Content Area -->
    <section class="itinerary-content">
      <div class="section-container content-inner">
        <!-- Main Content -->
        <div class="content" id="main-content">

          {/* Overview */}
          <div id="overview" class="overview-section content-section">
            <h2>Overview</h2>
            <Fragment set:html={holiday.overview.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />

            {holiday.whatsIncluded.length > 0 && (
              <>
                <h3 class="sub-heading">What's Included</h3>
                <ul class="custom-bullets">
                  {holiday.whatsIncluded.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </>
            )}

            {holiday.highlights.length > 0 && (
              <>
                <h3 class="sub-heading">Highlights</h3>
                <ul class="custom-bullets">
                  {holiday.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              </>
            )}
          </div>

          {/* Accommodation */}
          {holiday.accommodations.length > 0 && (
            <div id="accommodation" class="accommodation-section content-section">
              <h2>Accommodation &amp; Facilities</h2>
              {holiday.accommodations.map((acc, accIdx) => (
                <div class="desc">
                  <div class="acc-title">{acc.name}</div>
                  {acc.stars && (
                    <div class="hotel-stars">{'★'.repeat(acc.stars)}</div>
                  )}
                  {acc.images.length > 0 && (
                    <div class="img-carousel" data-carousel={`acc-${accIdx}`}>
                      <div class="img-carousel-viewport">
                        {acc.images.map((img, i) => (
                          <img
                            src={img}
                            alt={`${acc.name} - ${i + 1}`}
                            loading="lazy"
                            class={i === 0 ? 'img-carousel-slide active' : 'img-carousel-slide'}
                            data-slide-index={i}
                          />
                        ))}
                      </div>
                      {acc.images.length > 1 && (
                        <>
                          <button class="img-carousel-prev" aria-label="Previous">&#10094;</button>
                          <button class="img-carousel-next" aria-label="Next">&#10095;</button>
                        </>
                      )}
                      <button class="img-carousel-expand" aria-label="Fullscreen">
                        <img src="/icons/expand-icon.svg" alt="" />
                      </button>
                      <div class="img-carousel-counter">{`1 / ${acc.images.length}`}</div>
                    </div>
                  )}
                  <Fragment set:html={acc.description.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
                </div>
              ))}
            </div>
          )}

          {/* Itinerary */}
          {holiday.itinerary.length > 0 && (
            <div id="itinerary" class="itinerary-section content-section">
              <h2>Itinerary</h2>
              <p class="itinerary-desc">Explore the day-by-day breakdown of your journey through {holiday.destination}.</p>
              {holiday.itinerary.map((item, i) => (
                <div class="accordion-panel">
                  <div class="panel-header" data-panel={`panel-${i}`} role="button" tabindex="0" aria-expanded={i === 0 ? 'true' : 'false'}>
                    <div class="mobile-wrap">
                      <div class="day">{item.day}</div>
                      <div>
                        <div class="label">{item.title}</div>
                      </div>
                    </div>
                    <span class={i === 0 ? 'panel-icon icon-less-minus' : 'panel-icon icon-more-plus'}></span>
                  </div>
                  <div class="panel-content" style={i === 0 ? 'display:block;' : 'display:none;'}>
                    <div class="desc">
                      <Fragment set:html={item.description.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* Reviews */}
          {holiday.review && (
            <div id="reviews" class="reviews-section content-section">
              <h2>Reviews</h2>
              <div class="reviews-content">
                <Fragment set:html={holiday.review.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
              </div>
            </div>
          )}

          {/* Gallery */}
          {holiday.galleryImages.length > 0 && (
            <div id="gallery" class="gallery-section content-section">
              <h2>Gallery</h2>
              <div class="img-carousel" data-carousel="gallery">
                <div class="img-carousel-viewport">
                  {holiday.galleryImages.map((img, i) => (
                    <img
                      src={img}
                      alt={`${holiday.title} - ${i + 1}`}
                      loading="lazy"
                      class={i === 0 ? 'img-carousel-slide active' : 'img-carousel-slide'}
                      data-slide-index={i}
                    />
                  ))}
                </div>
                {holiday.galleryImages.length > 1 && (
                  <>
                    <button class="img-carousel-prev" aria-label="Previous">&#10094;</button>
                    <button class="img-carousel-next" aria-label="Next">&#10095;</button>
                  </>
                )}
                <button class="img-carousel-expand" aria-label="Fullscreen">
                  <img src="/icons/expand-icon.svg" alt="" />
                </button>
                <div class="img-carousel-counter">{`1 / ${holiday.galleryImages.length}`}</div>
              </div>
            </div>
          )}

          {/* More Info */}
          {(holiday.otherInfo || holiday.otherInfoBullets.length > 0) && (
            <div id="otherinfo" class="other-info-section content-section">
              <h2>More Information</h2>
              {holiday.otherInfo && (
                <Fragment set:html={holiday.otherInfo.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
              )}
              {holiday.otherInfoBullets.length > 0 && (
                <ul class="custom-bullets">
                  {holiday.otherInfoBullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
            </div>
          )}

          {/* Lightbox */}
          <div class="lightbox" id="gallery-lightbox">
            <div class="lightbox-overlay"></div>
            <button class="lightbox-close">&times;</button>
            <button class="lightbox-prev">&#10094;</button>
            <button class="lightbox-next">&#10095;</button>
            <div class="lightbox-content">
              <img src="" alt="" class="lightbox-img" />
              <div class="lightbox-counter"></div>
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="sidebar" id="summary">
          <div class="wrap">
            <img src={holiday.sidebarImage} alt={holiday.title} loading="lazy" />
            <div class="overview">
              <div class="title">{holiday.title}</div>
              <ul>
                <li><span class="icon-compass"></span>{holiday.destination}</li>
                <li><span class="icon-nights"></span>{holiday.duration}</li>
                <li><span class="icon-board-basis"></span>{holiday.boardBasis}</li>
              </ul>
            </div>
            <div class="details">
              <span>{holiday.accommodations.length > 1 ? 'Hotels' : 'Hotel'} — {holiday.hotelClass || 'Various'}</span>
              {holiday.accommodations.length > 0 ? (
                <ul class="sidebar-hotels">
                  {holiday.accommodations.map((acc) => (
                    <li>{acc.name}</li>
                  ))}
                </ul>
              ) : (
                <p>{holiday.hotelClass || 'Various'}</p>
              )}
            </div>
            <div class="sidebar-ref">Ref: {holiday.id}</div>
            <div class="sidebar-price">
              <span id="sidebar-price-label">from</span>
              <div id="sidebar-price-value">{cheapestInclusive}</div>
            </div>
            <a href="#" class="btn-check-price-sidebar" id="btn-check-price-sidebar">{hasPricing ? 'Check Dates & Prices' : 'Check Price & Book'}<img src="/icons/more-icon-white.svg" alt="" class="icon-more" /></a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Call Expert CTA -->
  <section class="call-expert-section">
    <div class="section-container">
      <div class="call-expert">
        <div class="call-expert-text">
          <div class="call-expert-title">Can't decide on a destination?</div>
          <p>A nice problem to have! Why not speak to one of our travel experts?</p>
          <div class="call-expert-phone">Call us on <a href="tel:02081830518"><span>0208 183 0518</span></a></div>
          <p>or alternatively</p>
          <a href="/contact" class="btn-primary call-expert-btn">Request A Call Back</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Posts + Newsletter Section -->
  <section class="blog-posts-section">
    <div class="section-container">
      <p class="section-label">read all about it</p>
      <h2>Our Latest Blog Posts</h2>
      <div class="blog-grid">
        {latestBlogs.map((blog) => (
          <div class="blog-card">
            <img src={blog.image} alt={blog.title} loading="lazy" />
            <div class="blog-card-title">{blog.title}</div>
            <div class="blog-card-date">
              <img src="/icons/calendar-icon-black.svg" alt="" class="icon-calendar" />
              {blog.date}
            </div>
            <p>{blog.excerpt.substring(0, 120)}...</p>
            <a href={`/blog/${blog.slug}`}>Read More <img src="/icons/more-icon.svg" alt="" class="icon-more-teal" /></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Calendar Modal -->
  {hasPricing && (
    <div class="pricing-modal" id="pricing-modal" role="dialog" aria-modal="true" aria-label="Dates and Prices">
      <div class="pricing-modal__card">
        <div class="pricing-modal__header">
          <div>
            <div class="pricing-modal__title">{holiday.title}</div>
            <div class="pricing-modal__meta">{holiday.destination} &bull; {holiday.duration} &bull; {holiday.boardBasis}</div>
          </div>
          <button class="pricing-modal__close" type="button" id="pricing-modal-close" aria-label="Close">&times;</button>
        </div>
        <div class="pricing-modal__controls">
          <div class="pricing-modal__control-group">
            <label for="modal-airport-select">Departing from</label>
            <select id="modal-airport-select" class="pricing-modal__select">
              {airportPrices.map((ap: any) => (
                <option value={ap.code}>{ap.name} — from {ap.inclusiveFormatted}/pp</option>
              ))}
            </select>
          </div>
          <div class="pricing-modal__control-group">
            <label for="modal-pax-select">Passengers</label>
            <select id="modal-pax-select" class="pricing-modal__select">
              <option value="1">1 passenger</option>
              <option value="2" selected>2 passengers</option>
              <option value="3">3 passengers</option>
              <option value="4">4 passengers</option>
            </select>
          </div>
        </div>
        <div class="pricing-modal__month-nav">
          <button type="button" class="pricing-modal__month-arrow pricing-modal__month-arrow--prev" id="month-prev" aria-label="Previous month">
            <img src="/icons/calendar-arrow.svg" alt="" />
          </button>
          <div class="pricing-modal__month-label" id="month-label"></div>
          <button type="button" class="pricing-modal__month-arrow pricing-modal__month-arrow--next" id="month-next" aria-label="Next month">
            <img src="/icons/calendar-arrow.svg" alt="" />
          </button>
        </div>
        <div class="pricing-modal__calendar" id="pricing-calendar-grid"></div>
        <div class="pricing-modal__legend">
          <span class="pricing-modal__legend-item pricing-modal__legend-item--best">Best price</span>
          <span class="pricing-modal__legend-item pricing-modal__legend-item--mid">Mid range</span>
          <span class="pricing-modal__legend-item pricing-modal__legend-item--peak">Peak</span>
        </div>
        <div class="pricing-modal__summary" id="pricing-modal-summary">
          <div class="pricing-modal__summary-info" id="modal-summary-info">Select a date to see pricing</div>
          <button type="button" class="pricing-modal__book-btn" id="modal-book-btn" disabled>Select a Date</button>
        </div>
      </div>
    </div>
  )}

  <!-- Mobile Bottom Bar -->
  {hasPricing && (
    <div class="mobile-price-bar" id="mobile-price-bar">
      <div class="mobile-price-bar__price">
        <span class="mobile-price-bar__label" id="mobile-price-label">from</span>
        <span class="mobile-price-bar__value" id="mobile-price-value">{cheapestInclusive}<small>/pp</small></span>
      </div>
      <button type="button" class="mobile-price-bar__btn" id="btn-mobile-pricing">Check Dates &amp; Prices</button>
    </div>
  )}

  <!-- Pricing data for client JS -->
  {hasPricing && (
    <script type="application/json" id="pricing-data" set:html={pricingJson} />
  )}

  <!-- Local charges data for client JS -->
  {localCharges > 0 && (
    <script type="application/json" id="local-charges-data" set:html={localChargesJson} />
  )}

  <!-- Holiday meta for enquiry form -->
  <script type="application/json" id="holiday-meta" set:html={JSON.stringify({
    id: holiday.id,
    title: holiday.title,
    destination: holiday.destination,
    duration: holiday.duration,
    boardBasis: holiday.boardBasis,
  })} />

  <!-- Package Enquiry Modal -->
  <div class="enquiry-modal" id="enquiry-modal" role="dialog" aria-modal="true" aria-label="Package Enquiry">
    <div class="enquiry-modal__card">
      <div class="enquiry-modal__header">
        <div>
          <div class="enquiry-modal__title">Booking Requested</div>
          <div class="enquiry-modal__subtitle">{holiday.title}</div>
        </div>
        <button class="enquiry-modal__close" type="button" id="enquiry-modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="enquiry-modal__summary" id="enquiry-summary">
        <div class="enquiry-modal__summary-row">
          <span>{holiday.destination}</span>
          <span>&bull;</span>
          <span>{holiday.duration}</span>
          <span>&bull;</span>
          <span>{holiday.boardBasis}</span>
        </div>
        <div class="enquiry-modal__summary-details" id="enquiry-selected-details"></div>
      </div>
      <form id="enquiry-form" class="enquiry-modal__form">
        <div class="enquiry-modal__field-row">
          <div class="enquiry-modal__field">
            <label for="enq-first-name">First Name <span class="enquiry-modal__required">(Required)</span></label>
            <input id="enq-first-name" name="first_name" type="text" placeholder="First name" required />
          </div>
          <div class="enquiry-modal__field">
            <label for="enq-last-name">Last Name <span class="enquiry-modal__required">(Required)</span></label>
            <input id="enq-last-name" name="last_name" type="text" placeholder="Last name" required />
          </div>
        </div>
        <div class="enquiry-modal__field">
          <label for="enq-email">Email <span class="enquiry-modal__required">(Required)</span></label>
          <input id="enq-email" name="email" type="email" placeholder="Email" required />
        </div>
        <div class="enquiry-modal__field">
          <label for="enq-phone">Phone Number <span class="enquiry-modal__required">(Required)</span></label>
          <input id="enq-phone" name="phone" type="tel" placeholder="Phone number" required />
        </div>
        <div class="enquiry-modal__actions">
          <button type="submit" class="enquiry-modal__submit" id="enquiry-submit-btn">Submit Enquiry</button>
        </div>
        <p class="enquiry-modal__note">Or call us on <a href="tel:02081830518">0208 183 0518</a></p>
      </form>
      <div class="enquiry-modal__success" id="enquiry-success" style="display:none;">
        <div class="enquiry-modal__success-icon">&#10003;</div>
        <h3>Thank you!</h3>
        <p>Your enquiry has been submitted.<br />One of our travel experts will be in touch shortly.</p>
        <p class="enquiry-modal__success-phone">Or call us now on <a href="tel:02081830518">0208 183 0518</a></p>
      </div>
    </div>
  </div>

  <Newsletter />
  <Footer />
  {hasPricing ? <Fragment /> : <MobileCallCTA />}
</BaseLayout>

