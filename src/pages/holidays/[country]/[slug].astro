---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import MobileNav from '../../../components/MobileNav.astro';
import Footer from '../../../components/Footer.astro';
import MobileCallCTA from '../../../components/MobileCallCTA.astro';
import { allPublishedHolidays } from '../../../data/holidays';
import type { HolidayDetail } from '../../../data/holidays';
import { allBlogs } from '../../../data/blogs';

export function getStaticPaths() {
  return allPublishedHolidays.map((h) => ({
    params: { country: h.countrySlug, slug: h.slug },
    props: { holiday: h },
  }));
}

const { holiday } = Astro.props as { holiday: HolidayDetail };
const latestBlogs = allBlogs.slice(0, 4);
---

<BaseLayout title={`${holiday.title} | Holidays - Flights and Packages`} description={holiday.overview ? holiday.overview.substring(0, 160) : holiday.description}>
  <Header />
  <MobileNav />

  <!-- Hero Section -->
  <section class="itinerary-hero">
    <div class="hero-bg" style={`background-image: url('${holiday.heroImage}')`}></div>
    <div class="breadcrumbs">
      <a href="/">Home</a>
      <span class="icon-breadcrumb"></span>
      <a href="/holidays">Destinations</a>
      <span class="icon-breadcrumb"></span>
      <a href={`/holidays/${holiday.countrySlug}`}>{holiday.country}</a>
      <span class="icon-breadcrumb"></span>
      <a href="javascript:void(0)">{holiday.title}</a>
    </div>
    <div class="hero-content">
      <div class="hero-label">discover</div>
      <h1>{holiday.title}</h1>
    </div>
  </section>

  <!-- Search / Price Bar -->
  <section class="search-section">
    <div class="search-form section-container">
      <div class="form-box">
        <p class="form-p-title">{holiday.title}</p>
        <p class="para2">{holiday.destination} &bull; {holiday.duration} &bull; {holiday.boardBasis}</p>
      </div>
      <div class="price-area">
        <div class="price-wrap">
          <span class="price-from">from</span>
          <div class="price-amount">&pound;{holiday.price}<span class="price-pp">/pp</span></div>
        </div>
        <a href="#" class="btn-check-price">Check Price &amp; Book<img src="/icons/more-icon-white.svg" alt="" class="icon-more" /></a>
      </div>
    </div>
  </section>

  <!-- Tab Navigation -->
  <div class="tabs" id="tabs-container">
    <div id="tab_navigation" class="itinerary-header">
      <div class="section-container header-inner">
        <div class="mobile-tab-toggle">
          <div class="drop-down">
            <span class="current">Overview</span>
            <span class="icon-sort-by"></span>
          </div>
          <button class="btn-summary summary-btn">Summary</button>
        </div>
        <ul class="tab-list">
          <li class="ui-tabs-active"><a href="#overview">Overview</a></li>
          {holiday.accommodations.length > 0 && (
            <li><a href="#accommodation">Accommodation</a></li>
          )}
          {holiday.itinerary.length > 0 && (
            <li><a href="#itinerary">Itinerary</a></li>
          )}
          {holiday.review && (
            <li><a href="#reviews">Reviews</a></li>
          )}
          {holiday.galleryImages.length > 0 && (
            <li><a href="#gallery">Gallery</a></li>
          )}
          {(holiday.otherInfo || holiday.otherInfoBullets.length > 0) && (
            <li><a href="#otherinfo">More Info</a></li>
          )}
        </ul>
      </div>
    </div>

    <!-- Content Area -->
    <section class="itinerary-content">
      <div class="section-container content-inner">
        <!-- Main Content -->
        <div class="content" id="main-content">

          {/* Overview */}
          <div id="overview" class="overview-section content-section">
            <h3>Overview</h3>
            <Fragment set:html={holiday.overview.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />

            {holiday.whatsIncluded.length > 0 && (
              <>
                <h3 style="margin-top: 40px;">What's Included</h3>
                <ul class="custom-bullets">
                  {holiday.whatsIncluded.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </>
            )}

            {holiday.highlights.length > 0 && (
              <>
                <h3 style="margin-top: 40px;">Highlights</h3>
                <ul class="custom-bullets">
                  {holiday.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              </>
            )}
          </div>

          {/* Accommodation */}
          {holiday.accommodations.length > 0 && (
            <div id="accommodation" class="accommodation-section content-section">
              <h3>Accommodation &amp; Facilities</h3>
              {holiday.accommodations.map((acc, accIdx) => (
                <div class="desc">
                  <div class="acc-title">{acc.name}</div>
                  {acc.stars && (
                    <div class="hotel-stars">{'★'.repeat(acc.stars)}</div>
                  )}
                  {acc.images.length > 0 && (
                    <div class="img-carousel" data-carousel={`acc-${accIdx}`}>
                      <div class="img-carousel-viewport">
                        {acc.images.map((img, i) => (
                          <img
                            src={img}
                            alt={`${acc.name} - ${i + 1}`}
                            loading="lazy"
                            class={i === 0 ? 'img-carousel-slide active' : 'img-carousel-slide'}
                            data-slide-index={i}
                          />
                        ))}
                      </div>
                      {acc.images.length > 1 && (
                        <>
                          <button class="img-carousel-prev" aria-label="Previous">&#10094;</button>
                          <button class="img-carousel-next" aria-label="Next">&#10095;</button>
                        </>
                      )}
                      <button class="img-carousel-expand" aria-label="Fullscreen">
                        <img src="/icons/expand-icon.svg" alt="" />
                      </button>
                      <div class="img-carousel-counter">{`1 / ${acc.images.length}`}</div>
                    </div>
                  )}
                  <Fragment set:html={acc.description.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
                </div>
              ))}
            </div>
          )}

          {/* Itinerary */}
          {holiday.itinerary.length > 0 && (
            <div id="itinerary" class="itinerary-section content-section">
              <h3>Itinerary</h3>
              <p class="itinerary-desc">Explore the day-by-day breakdown of your journey through {holiday.destination}.</p>
              {holiday.itinerary.map((item, i) => (
                <div class="accordion-panel">
                  <div class="panel-header" data-panel={`panel-${i}`}>
                    <div class="mobile-wrap">
                      <div class="day">{item.day}</div>
                      <div>
                        <div class="label">{item.title}</div>
                      </div>
                    </div>
                    <span class={i === 0 ? 'panel-icon icon-less-minus' : 'panel-icon icon-more-plus'}></span>
                  </div>
                  <div class="panel-content" style={i === 0 ? 'display:block;' : 'display:none;'}>
                    <div class="desc">
                      <Fragment set:html={item.description.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* Reviews */}
          {holiday.review && (
            <div id="reviews" class="reviews-section content-section">
              <h3>Reviews</h3>
              <div class="reviews-content">
                <Fragment set:html={holiday.review.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
              </div>
            </div>
          )}

          {/* Gallery */}
          {holiday.galleryImages.length > 0 && (
            <div id="gallery" class="gallery-section content-section">
              <h3>Gallery</h3>
              <div class="img-carousel" data-carousel="gallery">
                <div class="img-carousel-viewport">
                  {holiday.galleryImages.map((img, i) => (
                    <img
                      src={img}
                      alt={`${holiday.title} - ${i + 1}`}
                      loading="lazy"
                      class={i === 0 ? 'img-carousel-slide active' : 'img-carousel-slide'}
                      data-slide-index={i}
                    />
                  ))}
                </div>
                {holiday.galleryImages.length > 1 && (
                  <>
                    <button class="img-carousel-prev" aria-label="Previous">&#10094;</button>
                    <button class="img-carousel-next" aria-label="Next">&#10095;</button>
                  </>
                )}
                <button class="img-carousel-expand" aria-label="Fullscreen">
                  <img src="/icons/expand-icon.svg" alt="" />
                </button>
                <div class="img-carousel-counter">{`1 / ${holiday.galleryImages.length}`}</div>
              </div>
            </div>
          )}

          {/* More Info */}
          {(holiday.otherInfo || holiday.otherInfoBullets.length > 0) && (
            <div id="otherinfo" class="other-info-section content-section">
              <h3>More Information</h3>
              {holiday.otherInfo && (
                <Fragment set:html={holiday.otherInfo.replace(/\n\n/g, '</p><p>').replace(/^/, '<p>').replace(/$/, '</p>')} />
              )}
              {holiday.otherInfoBullets.length > 0 && (
                <ul class="custom-bullets">
                  {holiday.otherInfoBullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
            </div>
          )}

          {/* Lightbox */}
          <div class="lightbox" id="gallery-lightbox">
            <div class="lightbox-overlay"></div>
            <button class="lightbox-close">&times;</button>
            <button class="lightbox-prev">&#10094;</button>
            <button class="lightbox-next">&#10095;</button>
            <div class="lightbox-content">
              <img src="" alt="" class="lightbox-img" />
              <div class="lightbox-counter"></div>
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="sidebar" id="summary">
          <div class="wrap">
            <img src={holiday.sidebarImage} alt={holiday.title} loading="lazy" />
            <div class="overview">
              <div class="title">{holiday.title}</div>
              <ul>
                <li><span class="icon-compass"></span>{holiday.destination}</li>
                <li><span class="icon-nights"></span>{holiday.duration}</li>
                <li><span class="icon-board-basis"></span>{holiday.boardBasis}</li>
              </ul>
            </div>
            <div class="details">
              <span>Departing from</span>
              <p>London</p>
              <span>Departures</span>
              <p>Multiple dates available</p>
              <span>Hotel class</span>
              <p>{holiday.hotelClass || 'Various'}</p>
            </div>
            <div class="sidebar-price">
              <span>from</span>
              <div>&pound;{holiday.price}</div>
            </div>
            <a href="#" class="btn-check-price-sidebar">Check Price &amp; Book<img src="/icons/more-icon-white.svg" alt="" class="icon-more" /></a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Call Expert CTA -->
  <section class="call-expert-section">
    <div class="section-container">
      <div class="call-expert">
        <div class="call-expert-text">
          <div class="call-expert-title">Can't decide on a destination?</div>
          <p>A nice problem to have! Why not speak to one of our travel experts?</p>
          <div class="call-expert-phone">Call us on <span>0208 183 0518</span></div>
          <p>or alternatively</p>
          <a href="/contact" class="btn-primary call-expert-btn">Request A Call Back</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Posts + Newsletter Section -->
  <section class="blog-posts-section">
    <div class="section-container">
      <h4>read all about it</h4>
      <h2>Our Latest Blog Posts</h2>
      <div class="blog-grid">
        {latestBlogs.map((blog) => (
          <div class="blog-card">
            <img src={blog.image} alt={blog.title} loading="lazy" />
            <div class="blog-card-title">{blog.title}</div>
            <div class="blog-card-date">
              <img src="/icons/calendar-icon-black.svg" alt="" class="icon-calendar" />
              {blog.date}
            </div>
            <p>{blog.excerpt.substring(0, 120)}...</p>
            <a href={`/blog/${blog.slug}`}>Read More <img src="/icons/more-icon.svg" alt="" class="icon-more-teal" /></a>
          </div>
        ))}
      </div>
    </div>
    <div class="footer-background"></div>
    <div class="section-container">
      <div class="newsletter">
        <div class="newsletter-text">
          <div class="newsletter-title">Subscribe to our newsletter</div>
          <span class="newsletter-desc">Get our latest news and offers delivered right to your inbox</span>
        </div>
        <form class="newsletter-form">
          <input type="email" placeholder="Enter email address" />
          <button type="submit" class="btn-primary newsletter-btn">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
  <MobileCallCTA />
</BaseLayout>

<style>
  /* ========================================
     HERO SECTION
     ======================================== */
  .itinerary-hero {
    margin-top: 100px;
    height: 500px;
    position: relative;
    max-width: 100%;
    margin-bottom: 0;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .itinerary-hero {
      margin-top: 50px;
      height: 484px;
    }
  }
  @media (max-width: 480px) {
    .itinerary-hero {
      margin-top: 10px;
      height: 392px;
    }
  }
  .hero-bg {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: 66% 50%;
    background-repeat: no-repeat;
  }
  @media (max-width: 768px) {
    .hero-bg {
      background-position: 12% 50%;
    }
  }

  /* Breadcrumbs */
  .itinerary-hero .breadcrumbs {
    position: absolute;
    left: 50px;
    top: 10px;
    z-index: 3;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    color: #ffffff;
  }
  @media (max-width: 768px) {
    .itinerary-hero .breadcrumbs { left: 20px; }
  }
  @media (max-width: 530px) {
    .itinerary-hero .breadcrumbs { max-width: 400px; }
  }
  @media (max-width: 450px) {
    .itinerary-hero .breadcrumbs { max-width: 335px; }
  }
  @media (max-width: 394px) {
    .itinerary-hero .breadcrumbs { max-width: 305px; }
  }
  @media (max-width: 350px) {
    .itinerary-hero .breadcrumbs { max-width: 240px; }
  }
  .itinerary-hero .breadcrumbs a {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 10px;
    line-height: 12px;
    color: #ffffff;
  }
  .itinerary-hero .breadcrumbs .icon-breadcrumb {
    padding: 0 5px;
    display: inline-block;
    width: 6px;
    height: 10px;
    background-image: url('/icons/breadcrumb-arrow.svg');
    background-size: contain;
    background-repeat: no-repeat;
    vertical-align: middle;
  }

  /* Hero Content */
  .hero-content {
    text-align: center;
    position: absolute;
    left: 0;
    right: 0;
    margin: auto;
    top: 145px;
    max-width: 1240px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 3;
    padding: 0 20px;
  }
  @media (max-width: 1260px) {
    .hero-content { max-width: 1040px; }
  }
  @media (max-width: 1100px) {
    .hero-content { max-width: 880px; }
  }
  @media (max-width: 940px) {
    .hero-content { max-width: 730px; top: 105px; }
  }
  @media (max-width: 760px) {
    .hero-content { max-width: 580px; }
  }
  @media (max-width: 610px) {
    .hero-content { max-width: 500px; top: 55px; }
  }
  @media (max-width: 530px) {
    .hero-content { max-width: 420px; }
  }
  @media (max-width: 450px) {
    .hero-content { max-width: 365px; }
  }
  @media (max-width: 394px) {
    .hero-content { max-width: 335px; }
  }
  @media (max-width: 350px) {
    .hero-content { max-width: 290px; }
  }
  .hero-label {
    font-family: "BentonSansBold", sans-serif;
    font-size: 14px;
    line-height: 24px;
    letter-spacing: 5px;
    text-transform: uppercase;
    padding-bottom: 10px;
    color: #ffffff;
  }
  .hero-content h1 {
    color: #ffffff;
    padding-bottom: 25px;
    font-family: 'CaslonGraphiqueEF', Georgia, serif;
    font-size: 48px;
    line-height: 50px;
    margin: 0;
  }
  @media (max-width: 768px) {
    .hero-content h1 { font-size: 38px; line-height: 40px; }
  }
  @media (max-width: 450px) {
    .hero-content h1 { font-size: 36px; line-height: 36px; }
  }

  /* ========================================
     SEARCH / PRICE BAR
     ======================================== */
  .search-section {
    left: 0;
    right: 0;
    margin: auto;
    width: 100%;
    top: 440px;
    position: absolute;
    z-index: 3;
    color: #ffffff;
  }
  @media (max-width: 940px) {
    .search-section { top: 400px; }
  }
  @media (max-width: 768px) {
    .search-section { top: 290px; }
  }
  @media (max-width: 480px) {
    .search-section { top: 170px; }
  }
  @media (max-width: 394px) {
    .search-section { top: 260px; }
  }
  .search-form {
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.2);
    height: 96px;
    background-color: rgba(0, 0, 0, 0.5);
    padding: 0 30px;
  }
  @media (max-width: 1100px) {
    .search-form {
      flex-direction: column;
      height: auto;
    }
  }
  @media (max-width: 480px) {
    .search-form {
      padding: 10px 30px 5px;
    }
  }
  .form-box {
    height: 52px;
    width: 100%;
    flex: 2;
  }
  @media (max-width: 1100px) {
    .form-box {
      display: flex;
      align-items: center;
      padding-top: 10px;
      text-align: center;
      flex-direction: column;
    }
  }
  .form-box p {
    color: #ffffff;
  }
  .form-box .form-p-title {
    font-size: 29px;
    line-height: 30px;
    margin: 0;
  }
  .form-box .para2 {
    max-width: 100%;
    margin: 0 auto;
    font-size: 14px;
  }
  @media (max-width: 610px) {
    .form-box p { font-size: 14px; }
    .form-box .form-p-title {
      font-size: 22px;
      line-height: 26px;
      padding-bottom: 15px;
    }
    .form-box .para2 { max-width: 80%; }
  }

  .price-area {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: flex-end;
  }
  @media (max-width: 1100px) {
    .price-area { padding-top: 10px; }
  }
  @media (max-width: 610px) {
    .price-area {
      flex-direction: column;
      padding-top: 20px;
    }
  }
  .price-area .price-wrap {
    padding-right: 25px;
    padding-bottom: 10px;
  }
  @media (max-width: 610px) {
    .price-area .price-wrap {
      display: flex;
      padding-right: 0;
    }
  }
  .price-area .price-from {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    line-height: 33px;
    color: #ffffff;
  }
  @media (max-width: 610px) {
    .price-area .price-from {
      line-height: 14px;
      padding-top: 17px;
      padding-right: 5px;
    }
  }
  .price-area .price-amount {
    font-family: "CaslonGraphiqueEF", Georgia, serif;
    font-size: 40px;
    line-height: 20px;
    color: #ffffff;
  }
  @media (max-width: 610px) {
    .price-area .price-amount { font-size: 36px; }
  }
  @media (max-width: 450px) {
    .price-area .price-amount { font-size: 32px; }
  }
  @media (max-width: 350px) {
    .price-area .price-amount { font-size: 28px; }
  }
  .price-area .price-pp {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    white-space: nowrap;
    color: #ffffff;
  }

  .btn-check-price {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 291px;
    height: 64px;
    background-color: #ff7f00;
    color: #ffffff;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 16px;
    letter-spacing: 1px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    box-shadow: 0 20px 20px rgba(0, 0, 0, 0.2);
    text-decoration: none;
    line-height: 23px;
  }
  .btn-check-price:hover {
    background-color: #e67300;
  }
  @media (max-width: 610px) {
    .btn-check-price {
      margin-bottom: 20px;
      margin-top: 10px;
    }
  }
  @media (max-width: 530px) {
    .btn-check-price {
      width: 222px;
      font-size: 12px;
      padding: 0;
    }
  }
  .btn-check-price .icon-more {
    padding-left: 18px;
    width: 18px;
    height: auto;
  }
  @media (max-width: 530px) {
    .btn-check-price .icon-more { padding-left: 8px; }
  }

  /* ========================================
     TAB NAVIGATION HEADER
     ======================================== */
  .itinerary-header {
    background-color: #ffffff;
    height: 100px;
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.2);
    z-index: 3;
    position: relative;
    transform: translateY(0);
    transition: transform 0.2s;
  }
  @media (max-width: 768px) {
    .itinerary-header {
      height: 70px;
      background-color: #f4f4f4;
    }
  }
  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0;
    height: 100px;
  }
  @media (max-width: 768px) {
    .header-inner { height: 70px; }
  }

  .tab-list {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: space-between;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  @media (max-width: 768px) {
    .tab-list { display: none; }
  }
  .tab-list li {
    border-bottom: 4px solid transparent;
  }
  .tab-list li.ui-tabs-active {
    border-bottom: 4px solid #20A1AA;
  }
  .tab-list li a {
    display: inline-block;
    line-height: 96px;
    font-family: "BentonSansMedium", sans-serif;
    color: #282828;
    text-decoration: none;
    font-size: 16px;
  }
  .tab-list li a:focus {
    outline: none;
  }
  @media (max-width: 1100px) and (min-width: 769px) {
    .tab-list li a {
      display: flex;
      max-width: 145px;
      line-height: normal;
      height: 96px;
      align-items: center;
      text-align: center;
    }
  }

