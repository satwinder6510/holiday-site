---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import MobileNav from '../../../components/MobileNav.astro';
import PageHero from '../../../components/PageHero.astro';
import Footer from '../../../components/Footer.astro';
import MobileCallCTA from '../../../components/MobileCallCTA.astro';
import { countries } from '../../../data/countries';
import { mockHolidays } from '../../../data/mockHolidays';

export function getStaticPaths() {
  // Get unique country slugs from the countries data
  const uniqueCountries = [...new Set(countries.map(c => c.name))];
  return uniqueCountries.map((name) => {
    const slug = name.replace(/\s+/g, '-');
    return {
      params: { country: slug },
      props: { countryName: name },
    };
  });
}

const { countryName } = Astro.props;
const countrySlug = countryName.replace(/\s+/g, '-');
const countryHolidays = mockHolidays.filter(h => h.country === countryName);
// If no holidays match this country exactly, show all holidays as template
const holidays = countryHolidays.length > 0 ? countryHolidays : mockHolidays;
const bannerImage = `https://admin.citiesandbeaches.com/images/countries/${countrySlug}_banner.jpg`;
---

<BaseLayout title={`${countryName} Holidays | Flights and Packages`} description={`Browse our latest ${countryName} holiday deals. Find flights and packages to ${countryName}.`}>
  <Header />
  <MobileNav />

  <!-- Custom Hero -->
  <section class="country-hero" style={`background-image: url('${bannerImage}')`}>
    <div class="breadcrumbs">
      <a href="/">Home</a>
      <img src="/icons/breadcrumb-arrow.svg" alt="" class="breadcrumb-icon" />
      <a href="/holidays/destinations">Destinations</a>
      <img src="/icons/breadcrumb-arrow.svg" alt="" class="breadcrumb-icon" />
      <span>{countryName}</span>
    </div>
    <div class="hero-content">
      <div class="hero-subtitle">discover</div>
      <h1>{countryName} Holidays</h1>
    </div>
  </section>

  <!-- Search Bar Section -->
  <div class="search-section section-container">
    <div class="search-form">
      <form>
        <div class="mobile-wrap">
          <div class="form-box">
            <label for="destination">Destination</label>
            <div class="input">
              <input type="text" id="destination" name="destination" placeholder="Where to?" value={countryName} />
            </div>
          </div>
          <div class="form-box">
            <label for="airport">Departing from</label>
            <div class="input">
              <select id="airport" name="airport">
                <option value="">Any airport</option>
                <option value="London Heathrow">London Heathrow</option>
                <option value="London Gatwick">London Gatwick</option>
                <option value="Manchester">Manchester</option>
                <option value="Birmingham">Birmingham</option>
              </select>
            </div>
          </div>
          <div class="form-box">
            <label for="month">Departure month</label>
            <div class="input">
              <select id="month" name="month">
                <option value="">Any month</option>
                <option value="January">January</option>
                <option value="February">February</option>
                <option value="March">March</option>
                <option value="April">April</option>
                <option value="May">May</option>
                <option value="June">June</option>
                <option value="July">July</option>
                <option value="August">August</option>
                <option value="September">September</option>
                <option value="October">October</option>
                <option value="November">November</option>
                <option value="December">December</option>
              </select>
            </div>
          </div>
          <div class="form-box">
            <label for="passengers">Passengers</label>
            <div class="input">
              <select id="passengers" name="passengers">
                <option value="2">2 Adults</option>
                <option value="1">1 Adult</option>
                <option value="3">3 Adults</option>
                <option value="4">4 Adults</option>
              </select>
            </div>
          </div>
        </div>
        <button type="submit" class="btn-primary search-submit-btn">Search</button>
      </form>
    </div>
    <!-- Floating mobile search button -->
    <a href="/holidays/search" class="btn-primary search-btn">
      <span class="icon-search"></span>
      Search
    </a>
  </div>

  <!-- Intro Section -->
  <section class="intro-section section-container">
    <p class="intro-text">
      {countryName} is a wonderful destination offering a rich blend of culture, history, and natural beauty.
      From vibrant cities to stunning landscapes, there is something for every type of traveller.
      Whether you are looking for relaxation on sun-drenched beaches, adventure in the great outdoors,
      or a journey through centuries of fascinating heritage, {countryName} delivers an unforgettable holiday experience.
    </p>
    <p class="intro-text-extra hide">
      Our carefully curated {countryName} holiday packages include flights, accommodation, and transfers to take the
      stress out of planning. Choose from luxury resorts, boutique hotels, and charming guesthouses, all handpicked
      by our travel experts. With departures from major UK airports and flexible booking options, your dream
      {countryName} holiday is just a click away. Browse our latest deals below or speak to one of our
      friendly travel advisors for a tailor-made quote.
    </p>
    <a class="read-more" href="javascript:void(0)">
      Read more
      <span class="icon-dropdown"></span>
    </a>
  </section>

  <!-- Holiday List Section -->
  <section class="holiday-list-section section-container">
    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Filter header -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Filters</div>
          <div class="reset">Reset</div>
        </div>
      </div>

      <!-- Board Basis filter -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Board basis</div>
          <span class="icon-pullup"></span>
        </div>
        <div class="sidebar-content">
          <div class="checkbox-option">
            <input type="checkbox" name="mealplan" id="bed-and-breakfast" value="Bed & Breakfast" />
            <label for="bed-and-breakfast">Bed & Breakfast</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="mealplan" id="half-board" value="Half Board" />
            <label for="half-board">Half Board</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="mealplan" id="all-inclusive" value="All Inclusive" />
            <label for="all-inclusive">All Inclusive</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="mealplan" id="room-only" value="Room Only" />
            <label for="room-only">Room Only</label>
          </div>
        </div>
      </div>

      <!-- Price Range filter -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Price range</div>
          <span class="icon-pullup"></span>
        </div>
        <div class="sidebar-content">
          <div class="price-boxes">
            <div>&pound;<span>199</span></div>
            <div>&pound;<span>1099</span></div>
          </div>
        </div>
      </div>

      <!-- Airport filter -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Airport</div>
          <span class="icon-pullup"></span>
        </div>
        <div class="sidebar-content">
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="london-heathrow" value="London Heathrow" />
            <label for="london-heathrow">London Heathrow</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="london-gatwick" value="London Gatwick" />
            <label for="london-gatwick">London Gatwick</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="manchester" value="Manchester" />
            <label for="manchester">Manchester</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="birmingham" value="Birmingham" />
            <label for="birmingham">Birmingham</label>
          </div>
        </div>
      </div>

      <!-- Mobile actions -->
      <div class="mobile-actions">
        <button class="btn-primary filter-apply-btn">Apply</button>
        <span class="reset">Reset</span>
      </div>
    </div>

    <!-- Content -->
    <div class="content">
      <!-- Sort bar -->
      <div class="search-sort">
        <div class="results">{holidays.length} results found</div>
        <div class="order">
          <div class="price">
            Price
            <div class="price-order active">Low to high</div>
            <div class="price-order">High to low</div>
          </div>
          <div class="mobile-filter-wrap">
            <div class="filter-btn">
              <span class="icon-filter"></span>
              Filter
            </div>
            <div class="sort">
              Sort by
              <div class="sort-order">
                <span class="current-option">Newest</span>
                <span class="icon-dropdown"></span>
              </div>
              <ul class="sort-order-list">
                <li class="sort-option">Newest</li>
                <li class="sort-option">Oldest</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Holiday cards -->
      <div class="holidays">
        {holidays.map((holiday) => (
          <div class="holiday">
            <span class="holiday-img" style={`background-image: url('${holiday.image}')`}></span>
            <a class="gallery-link" href={`/holidays/${holiday.countrySlug}/${holiday.slug}`}>
              <span class="icon-camera"></span>
              Gallery
            </a>
            <div class="details">
              <div>
                <div class="title">{holiday.title}</div>
                <ul>
                  <li><span class="icon-compass"></span>{holiday.destination}</li>
                  <li><span class="icon-nights"></span>{holiday.duration}</li>
                  <li><span class="icon-board-basis"></span>{holiday.boardBasis}</li>
                </ul>
              </div>
              <p>{holiday.description}</p>
              <div class="horizontal">
                <div class="price">
                  <span>from</span>
                  <div>&pound;{holiday.price}<span>/pp</span></div>
                </div>
                <a class="btn-primary view-more-btn" href={`/holidays/${holiday.countrySlug}/${holiday.slug}`}>
                  View More
                  <img src="/icons/more-icon-white.svg" alt="" class="icon-more" />
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Load More button -->
      <button class="btn-primary more-holidays">Load More Results</button>
    </div>

    <div style="clear:both"></div>
  </section>

  <Footer />
  <MobileCallCTA />
</BaseLayout>

<style>
  /* ===========================
     Country Hero Section
     =========================== */
  .country-hero {
    margin-top: 100px;
    height: 500px;
    background-position: 100%;
    background-size: cover;
    position: relative;
    color: #ffffff;
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 100%;
  }
  @media (max-width: 768px) {
    .country-hero {
      margin-top: 50px;
      height: 400px;
      background-position: center;
    }
  }
  @media (max-width: 450px) {
    .country-hero {
      height: 300px;
    }
  }

  .breadcrumbs {
    position: absolute;
    left: 50px;
    top: 10px;
    z-index: 3;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    color: #ffffff;
    display: flex;
    align-items: center;
  }
  @media (max-width: 768px) {
    .breadcrumbs { left: 20px; }
  }
  @media (max-width: 530px) {
    .breadcrumbs { max-width: 400px; }
  }
  @media (max-width: 450px) {
    .breadcrumbs { max-width: 335px; }
  }
  @media (max-width: 394px) {
    .breadcrumbs { max-width: 305px; }
  }
  @media (max-width: 350px) {
    .breadcrumbs { max-width: 240px; }
  }

  .breadcrumbs a,
  .breadcrumbs span {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 10px;
    line-height: 12px;
    color: #ffffff;
  }

  .breadcrumb-icon {
    padding: 0 5px;
    width: auto;
    height: 8px;
  }

  .hero-content {
    text-align: center;
    padding-bottom: 80px;
  }
  @media (max-width: 1260px) {
    .hero-content {
      padding-bottom: 120px;
    }
  }
  @media (max-width: 768px) {
    .hero-content {
      padding-bottom: 0px;
    }
  }

  .hero-subtitle {
    font-family: "BentonSansBold", sans-serif;
    font-size: 14px;
    line-height: 24px;
    letter-spacing: 5px;
    text-transform: uppercase;
    padding-bottom: 10px;
  }

  .hero-content h1 {
    color: #ffffff;
    padding-bottom: 25px;
    text-shadow: 2px 2px 5px #000;
  }

  /* ===========================
     Search Section Overlay
     =========================== */
  .search-section {
    position: absolute;
    top: 440px;
    left: 0;
    right: 0;
    margin: auto;
    width: 100%;
    z-index: 3;
  }
  @media (max-width: 1260px) {
    .search-section {
      max-width: 730px;
      top: 400px;
    }
  }
  @media (max-width: 768px) {
    .search-section {
      position: static;
    }
  }

  .search-form {
    border-radius: 2px;
    box-shadow: 0px 0px 8px rgba(0, 0, 0, 0.2);
    background-color: #ffffff;
    padding: 0 25px;
  }
  @media (max-width: 768px) {
    .search-form {
      display: none;
    }
  }
  .search-form form {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 96px;
    width: 100%;
  }
  @media (max-width: 1260px) {
    .search-form form {
      height: 164px;
    }
    .search-form {
      height: 164px;
    }
  }

  .search-form .mobile-wrap {
    display: flex;
    flex-grow: 1;
  }
  @media (max-width: 1260px) {
    .search-form .mobile-wrap {
      height: 124px;
      flex-direction: column;
      justify-content: space-between;
      align-items: center;
    }
  }

  .search-form .form-box {
    display: flex;
    justify-content: space-between;
    flex-direction: column;
    height: 52px;
    width: 100%;
    padding-right: 40px;
  }
  @media (max-width: 1260px) {
    .search-form .form-box {
      padding-right: 0px;
    }
  }
  .search-form .form-box label {
    font-family: "BentonSansBold", sans-serif;
    font-size: 14px;
    color: #282828;
  }
  .search-form .form-box .input {
    display: flex;
    position: relative;
    left: -15px;
  }
  .search-form .form-box .input input,
  .search-form .form-box .input select {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    color: #878787;
    border: none;
    outline: none;
    background: transparent;
    padding-left: 15px;
    width: 100%;
    cursor: pointer;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }

  .search-submit-btn {
    width: 161px;
    min-width: 161px;
    letter-spacing: 1px;
    height: 64px;
    margin: 0px;
    box-shadow: 0px 20px 20px rgba(0, 0, 0, 0.2);
  }

  /* Floating mobile search button */
  .search-btn {
    display: none;
  }
  @media (max-width: 768px) {
    .search-btn {
      display: flex;
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 3;
      width: 51px;
      min-width: 51px;
      height: 51px;
      font-size: 8px;
      letter-spacing: 0px;
      flex-direction: column;
      text-decoration: none;
    }
    .search-btn .icon-search {
      content: "";
      background-image: url('/icons/search-icon.svg');
      background-size: cover;
      background-position: center;
      width: 18px;
      height: 18px;
    }
  }

  /* ===========================
     Intro Section
     =========================== */
  .intro-section {
    margin-top: 80px;
    margin-bottom: 95px;
  }
  @media (max-width: 768px) {
    .intro-section {
      margin-top: 40px;
      margin-bottom: 50px;
    }
  }
  .intro-section p {
    padding-bottom: 1px;
  }
  @media (max-width: 768px) {
    .intro-section p {
      text-align: justify;
    }
  }
  .intro-section .read-more {
    vertical-align: middle;
    font-family: "BentonSansBold", sans-serif;
    color: #424242;
    text-decoration: none;
    display: inline-block;
    margin-top: 15px;
    cursor: pointer;
  }
  .intro-section .read-more .icon-dropdown {
    display: inline-block;
    width: 12px;
    height: 7px;
    background-image: url('/icons/dropdown-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    margin-left: 15px;
    transition: transform 0.3s;
  }
  .intro-section .read-more.expanded .icon-dropdown {
    transform: rotate(180deg);
  }

  /* ===========================
     Holiday List Section
     =========================== */
  .holiday-list-section {
    margin-top: 60px;
    margin-bottom: 0px;
  }
  @media (max-width: 768px) {
    .holiday-list-section {
      margin: 90px 0px 0px 0px;
      max-width: 100%;
    }
  }

  /* Sidebar */
  .holiday-list-section .sidebar {
    width: 281px;
    display: inline-block;
    padding-right: 32px;
  }
  @media (max-width: 768px) {
    .holiday-list-section .sidebar {
      display: none;
      margin: auto;
      padding-right: 0px;
    }
  }
  .holiday-list-section .sidebar.show {
    display: block;
  }

  /* Filter blocks */
  .holiday-list-section .sidebar .filter {
    padding-bottom: 25px;
    padding-top: 25px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
  }
  .holiday-list-section .sidebar .filter:first-child {
    padding-top: 0px;
    padding-bottom: 2px;
  }
  .holiday-list-section .sidebar .filter:first-child .sidebar-header {
    cursor: default;
  }
  @media (min-width: 768px) {
    .holiday-list-section .sidebar .filter:nth-last-child(2) {
      border: none;
    }
  }

  /* Sidebar header */
  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 20px;
    cursor: pointer;
  }
  .sidebar-header .type {
    font-family: "BentonSansBold", sans-serif;
    font-size: 18px;
    color: #424242;
  }
  .sidebar-header .reset {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    color: #B7B7B7;
    cursor: pointer;
  }
  .sidebar-header .icon-dropdown {
    width: 12px;
    height: 7px;
    background-image: url('/icons/dropdown-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    display: inline-block;
  }
  .sidebar-header .icon-pullup {
    width: 12px;
    height: 7px;
    background-image: url('/icons/dropdown-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    display: inline-block;
    transform: rotate(180deg);
  }

  /* Sidebar content */
  .sidebar-content {
    display: block;
  }

  /* Checkbox options */
  .checkbox-option {
    padding-left: 23px;
    font-size: 14px;
    padding-top: 10px;
    display: flex;
  }
  .checkbox-option input {
    display: none;
  }
  .checkbox-option input:checked + label:before {
    content: "";
    background-image: url('/icons/tick.svg');
    background-repeat: no-repeat;
    background-position-y: 2px;
  }
  .checkbox-option label {
    display: flex;
    color: #000000;
    cursor: pointer;
  }
  .checkbox-option label:before {
    background: #FFF;
    content: "";
    width: 14px;
    min-width: 14px;
    height: 14px;
    border: 1px solid #5e5e5e;
    border-radius: 2px;
    margin-right: 14px;
  }

  /* Price boxes */
  .price-boxes {
    display: flex;
    justify-content: space-between;
  }
  .price-boxes div {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 86px;
    height: 36px;
    border: 1px #5E5E5E solid;
    border-radius: 2px;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
  }

  /* Mobile actions */
  .mobile-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20px;
  }
  @media (min-width: 769px) {
    .mobile-actions {
      display: none;
    }
  }
  .mobile-actions .filter-apply-btn {
    margin: 0px;
    width: 140px;
    height: 45px;
  }
  .mobile-actions .reset {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    color: #B7B7B7;
  }

  /* Content area */
  .holiday-list-section .content {
    width: calc(100% - 281px);
    float: right;
    padding-left: 32px;
  }
  @media (max-width: 768px) {
    .holiday-list-section .content {
      width: 100%;
      padding-left: 0px;
    }
  }

  /* Search sort bar */
  .search-sort {
    display: flex;
    font-family: "BentonSansBold", sans-serif;
    color: #424242;
    padding-bottom: 22px;
    border-bottom: solid 1px rgba(66, 66, 66, 0.2);
    margin-bottom: 38px;
  }
  @media (max-width: 1100px) {
    .search-sort {
      padding-bottom: 2px;
    }
  }
  @media (max-width: 940px) {
    .search-sort {
      flex-direction: column;
    }
  }
  @media (max-width: 768px) {
    .search-sort {
      border: none;
      align-items: center;
      padding-bottom: 0px;
    }
  }
  .search-sort .results {
    flex-grow: 2;
  }
  .search-sort .order {
    display: flex;
    flex-grow: 1;
    justify-content: space-between;
  }
  @media (max-width: 1100px) {
    .search-sort .order {
      flex-direction: column;
      align-items: flex-end;
    }
  }
  @media (max-width: 940px) {
    .search-sort .order {
      align-items: flex-start;
    }
  }
  @media (max-width: 768px) {
    .search-sort .order {
      padding-top: 20px;
    }
  }

  /* Price order toggles */
  .search-sort .order .price {
    display: inline-block;
  }
  @media (max-width: 1100px) {
    .search-sort .order .price {
      margin-bottom: 5px;
    }
  }
  @media (max-width: 940px) {
    .search-sort .order .price {
      margin-top: 5px;
    }
  }
  @media (max-width: 768px) {
    .search-sort .order .price {
      margin: 0px;
    }
  }
  .search-sort .order .price .price-order {
    display: inline-block;
    font-family: "BentonSansMedium", sans-serif;
    color: #878787;
    padding-left: 20px;
    cursor: pointer;
  }
  .search-sort .order .price .price-order:last-child {
    border-left: 0.5px solid rgba(0, 0, 0, 0.5);
    margin-left: 15px;
  }
  @media (max-width: 450px) {
    .search-sort .order .price .price-order {
      font-size: 16px;
      padding-left: 5px;
    }
