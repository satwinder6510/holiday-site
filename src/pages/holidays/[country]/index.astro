<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Read more toggle
    const readMoreLink = document.querySelector('.read-more');
    const extraText = document.querySelector('.intro-text-extra');

    if (readMoreLink && extraText) {
      readMoreLink.addEventListener('click', () => {
        const isHidden = extraText.classList.contains('hide');
        if (isHidden) {
          extraText.classList.remove('hide');
          readMoreLink.textContent = '';
          readMoreLink.innerHTML = 'Read less <span class="icon-dropdown"></span>';
          readMoreLink.classList.add('expanded');
        } else {
          extraText.classList.add('hide');
          readMoreLink.textContent = '';
          readMoreLink.innerHTML = 'Read more <span class="icon-dropdown"></span>';
          readMoreLink.classList.remove('expanded');
        }
      });
    }

    // Sort dropdown toggle
    const sortOrder = document.querySelector('.sort-order');
    const sortOrderList = document.querySelector('.sort-order-list');

    if (sortOrder && sortOrderList) {
      sortOrder.addEventListener('click', () => {
        const isVisible = sortOrderList.style.display === 'block';
        sortOrderList.style.display = isVisible ? 'none' : 'block';
      });

      // Close dropdown when clicking a sort option
      const sortOptions = document.querySelectorAll('.sort-option');
      sortOptions.forEach((option) => {
        option.addEventListener('click', () => {
          const currentOption = document.querySelector('.current-option');
          if (currentOption) {
            currentOption.textContent = option.textContent;
          }
          sortOrderList.style.display = 'none';
        });
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!sortOrder.contains(e.target as Node) && !sortOrderList.contains(e.target as Node)) {
          sortOrderList.style.display = 'none';
        }
      });
    }

    // Filter sidebar toggle on mobile
    const filterBtn = document.querySelector('.filter-btn');
    const sidebar = document.querySelector('.sidebar');

    if (filterBtn && sidebar) {
      filterBtn.addEventListener('click', () => {
        sidebar.classList.toggle('show');
      });
    }

    // Apply button closes sidebar on mobile
    const applyBtn = document.querySelector('.filter-apply-btn');
    if (applyBtn && sidebar) {
      applyBtn.addEventListener('click', () => {
        sidebar.classList.remove('show');
      });
    }

    // Sidebar header accordion (skip the first filter header which is just "Filters")
    const filterHeaders = document.querySelectorAll('.filter .sidebar-header');
    filterHeaders.forEach((header, index) => {
      if (index === 0) return; // Skip the "Filters" header
      header.addEventListener('click', () => {
        const content = header.nextElementSibling as HTMLElement;
        const icon = header.querySelector('.icon-pullup, .icon-dropdown') as HTMLElement;
        if (content && content.classList.contains('sidebar-content')) {
          const isVisible = content.style.display !== 'none';
          content.style.display = isVisible ? 'none' : 'block';
          if (icon) {
            if (isVisible) {
              icon.classList.remove('icon-pullup');
              icon.classList.add('icon-dropdown');
              icon.style.transform = 'rotate(0deg)';
            } else {
              icon.classList.remove('icon-dropdown');
              icon.classList.add('icon-pullup');
              icon.style.transform = 'rotate(180deg)';
            }
          }
        }
      });
    });

    // Price order toggle
    const priceOrders = document.querySelectorAll('.search-sort .order .price .price-order');
    priceOrders.forEach((el) => {
      el.addEventListener('click', () => {
        priceOrders.forEach((p) => p.classList.remove('active'));
        el.classList.add('active');
      });
    });
  });
</script>
