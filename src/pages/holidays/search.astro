---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import MobileNav from '../../components/MobileNav.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import MobileCallCTA from '../../components/MobileCallCTA.astro';
import { listedHolidays, boardBasisOptions, priceRange } from '../../data/holidays';
---

<BaseLayout title="Search Results | Holidays - Flights and Packages" description="Browse our latest holiday deals. Find flights and packages to top destinations worldwide." noindex={true}>
  <Header />
  <MobileNav />
  <PageHero
    title="Search Results"
    breadcrumbLabel="Search Results"
    backgroundImage="/images/heroes/search.jpg"
    subtitle="discover"
  />

  <section class="holiday-list-section section-container">
    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Filter header -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Filters</div>
          <div class="reset">Reset</div>
        </div>
      </div>

      <!-- Board Basis filter -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Board basis</div>
          <span class="icon-pullup"></span>
        </div>
        <div class="sidebar-content">
          {boardBasisOptions.map((basis) => (
            <div class="checkbox-option">
              <input type="checkbox" name="mealplan" id={basis.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and')} value={basis} />
              <label for={basis.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and')}>{basis}</label>
            </div>
          ))}
        </div>
      </div>

      <!-- Price Range filter -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Price range</div>
          <span class="icon-pullup"></span>
        </div>
        <div class="sidebar-content">
          <div class="price-boxes">
            <div>&pound;<span>{priceRange.min}</span></div>
            <div>&pound;<span>{priceRange.max}</span></div>
          </div>
        </div>
      </div>

      <!-- Airport filter -->
      <div class="filter">
        <div class="sidebar-header">
          <div class="type">Airport</div>
          <span class="icon-pullup"></span>
        </div>
        <div class="sidebar-content">
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="london-heathrow" value="London Heathrow" />
            <label for="london-heathrow">London Heathrow</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="london-gatwick" value="London Gatwick" />
            <label for="london-gatwick">London Gatwick</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="manchester" value="Manchester" />
            <label for="manchester">Manchester</label>
          </div>
          <div class="checkbox-option">
            <input type="checkbox" name="airport" id="birmingham" value="Birmingham" />
            <label for="birmingham">Birmingham</label>
          </div>
        </div>
      </div>

      <!-- Mobile actions -->
      <div class="mobile-actions">
        <button class="btn-primary filter-apply-btn">Apply</button>
        <span class="reset">Reset</span>
      </div>
    </div>

    <!-- Content -->
    <div class="content">
      <!-- Sort bar -->
      <div class="search-sort">
        <div class="results">{listedHolidays.length} results found</div>
        <div class="order">
          <div class="price">
            Price
            <div class="price-order active">Low to high</div>
            <div class="price-order">High to low</div>
          </div>
          <div class="mobile-filter-wrap">
            <div class="filter-btn">
              <span class="icon-filter"></span>
              Filter
            </div>
            <div class="sort">
              Sort by
              <div class="sort-order">
                <span class="current-option">Newest</span>
                <span class="icon-dropdown"></span>
              </div>
              <ul class="sort-order-list">
                <li class="sort-option">Newest</li>
                <li class="sort-option">Oldest</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Holiday cards -->
      <div class="holidays">
        {listedHolidays.map((holiday) => (
          <div class="holiday">
            <span class="holiday-img" style={`background-image: url('${holiday.image}')`}></span>
            <a class="gallery-link" href={`/Holidays/${holiday.countrySlug}/${holiday.slug}`}>
              <span class="icon-camera"></span>
              Gallery
            </a>
            <div class="details">
              <div>
                <div class="title">{holiday.title}</div>
                <ul>
                  <li><span class="icon-compass"></span>{holiday.destination}</li>
                  <li><span class="icon-nights"></span>{holiday.duration}</li>
                  <li><span class="icon-board-basis"></span>{holiday.boardBasis}</li>
                </ul>
              </div>
              <p>{holiday.description}</p>
              <div class="horizontal">
                <div class="price">
                  <span>from</span>
                  <div>&pound;{Math.round(holiday.price + holiday.localChargesPp)}<span>/pp</span></div>
                </div>
                <a class="btn-primary view-more-btn" href={`/Holidays/${holiday.countrySlug}/${holiday.slug}`}>
                  View More
                  <img src="/icons/more-icon-white.svg" alt="" class="icon-more" />
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Load More button -->
      <button class="btn-primary more-holidays">Load More Results</button>
    </div>

    <div style="clear:both"></div>
  </section>

  <Newsletter />
  <Footer />
  <MobileCallCTA />
</BaseLayout>

<style>
  /* Holiday List Section */
  .holiday-list-section {
    margin-top: 60px;
    margin-bottom: 0px;
  }
  @media (max-width: 768px) {
    .holiday-list-section {
      margin: 90px 0px 0px 0px;
      max-width: 100%;
    }
  }

  /* Sidebar */
  .holiday-list-section .sidebar {
    width: 281px;
    display: inline-block;
    padding-right: 32px;
  }
  @media (max-width: 768px) {
    .holiday-list-section .sidebar {
      display: none;
      margin: auto;
      padding-right: 0px;
    }
  }
  .holiday-list-section .sidebar.show {
    display: block;
  }

  /* Filter blocks */
  .holiday-list-section .sidebar .filter {
    padding-bottom: 25px;
    padding-top: 25px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
  }
  .holiday-list-section .sidebar .filter:first-child {
    padding-top: 0px;
    padding-bottom: 2px;
  }
  .holiday-list-section .sidebar .filter:first-child .sidebar-header {
    cursor: default;
  }
  @media (min-width: 768px) {
    .holiday-list-section .sidebar .filter:nth-last-child(2) {
      border: none;
    }
  }

  /* Sidebar header */
  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 20px;
    cursor: pointer;
  }
  .sidebar-header .type {
    font-family: "BentonSansBold", sans-serif;
    font-size: 18px;
    color: #424242;
  }
  .sidebar-header .reset {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    color: #B7B7B7;
    cursor: pointer;
  }
  .sidebar-header .icon-dropdown {
    width: 12px;
    height: 7px;
    background-image: url('/icons/dropdown-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    display: inline-block;
  }
  .sidebar-header .icon-pullup {
    width: 12px;
    height: 7px;
    background-image: url('/icons/dropdown-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    display: inline-block;
    transform: rotate(180deg);
  }

  /* Sidebar content */
  .sidebar-content {
    display: block;
  }

  /* Checkbox options */
  .checkbox-option {
    padding-left: 23px;
    font-size: 14px;
    padding-top: 10px;
    display: flex;
  }
  .checkbox-option input {
    display: none;
  }
  .checkbox-option input:checked + label:before {
    content: "";
    background-image: url('/icons/tick.svg');
    background-repeat: no-repeat;
    background-position-y: 2px;
  }
  .checkbox-option label {
    display: flex;
    color: #000000;
    cursor: pointer;
  }
  .checkbox-option label:before {
    background: #FFF;
    content: "";
    width: 14px;
    min-width: 14px;
    height: 14px;
    border: 1px solid #5e5e5e;
    border-radius: 2px;
    margin-right: 14px;
  }

  /* Price boxes */
  .price-boxes {
    display: flex;
    justify-content: space-between;
  }
  .price-boxes div {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 86px;
    height: 36px;
    border: 1px #5E5E5E solid;
    border-radius: 2px;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
  }

  /* Mobile actions */
  .mobile-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20px;
  }
  @media (min-width: 769px) {
    .mobile-actions {
      display: none;
    }
  }
  .mobile-actions .filter-apply-btn {
    margin: 0px;
    width: 140px;
    height: 45px;
  }
  .mobile-actions .reset {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    color: #B7B7B7;
  }

  /* Content area */
  .holiday-list-section .content {
    width: calc(100% - 281px);
    float: right;
    padding-left: 32px;
  }
  @media (max-width: 768px) {
    .holiday-list-section .content {
      width: 100%;
      padding-left: 0px;
    }
  }

  /* Search sort bar */
  .search-sort {
    display: flex;
    font-family: "BentonSansBold", sans-serif;
    color: #424242;
    padding-bottom: 22px;
    border-bottom: solid 1px rgba(66, 66, 66, 0.2);
    margin-bottom: 38px;
  }
  @media (max-width: 1100px) {
    .search-sort {
      padding-bottom: 2px;
    }
  }
  @media (max-width: 940px) {
    .search-sort {
      flex-direction: column;
    }
  }
  @media (max-width: 768px) {
    .search-sort {
      border: none;
      align-items: center;
      padding-bottom: 0px;
    }
  }
  .search-sort .results {
    flex-grow: 2;
  }
  .search-sort .order {
    display: flex;
    flex-grow: 1;
    justify-content: space-between;
  }
  @media (max-width: 1100px) {
    .search-sort .order {
      flex-direction: column;
      align-items: flex-end;
    }
  }
  @media (max-width: 940px) {
    .search-sort .order {
      align-items: flex-start;
    }
  }
  @media (max-width: 768px) {
    .search-sort .order {
      padding-top: 20px;
    }
  }

  /* Price order toggles */
  .search-sort .order .price {
    display: inline-block;
  }
  @media (max-width: 1100px) {
    .search-sort .order .price {
      margin-bottom: 5px;
    }
  }
  @media (max-width: 940px) {
    .search-sort .order .price {
      margin-top: 5px;
    }
  }
  @media (max-width: 768px) {
    .search-sort .order .price {
      margin: 0px;
    }
  }
  .search-sort .order .price .price-order {
    display: inline-block;
    font-family: "BentonSansMedium", sans-serif;
    color: #878787;
    padding-left: 20px;
    cursor: pointer;
  }
  .search-sort .order .price .price-order:last-child {
    border-left: 0.5px solid rgba(0, 0, 0, 0.5);
    margin-left: 15px;
  }
  @media (max-width: 450px) {
    .search-sort .order .price .price-order {
      font-size: 16px;
      padding-left: 5px;
    }
    .search-sort .order .price .price-order:last-child {
      padding-left: 10px;
      margin-left: 5px;
    }
  }
  .search-sort .order .price .price-order.active {
    color: #20A1AA;
  }
  .search-sort .order .price.hide {
    display: none;
  }

  /* Mobile filter wrap */
  .mobile-filter-wrap {
    display: none;
  }
  @media (max-width: 768px) {
    .mobile-filter-wrap {
      position: absolute;
      width: 100%;
      top: -90px;
      left: 0px;
      right: 0px;
      background-color: #ffffff;
      box-shadow: 0px 0px 8px rgba(0, 0, 0, 0.2);
      display: flex;
      justify-content: space-between;
      padding: 20px;
      transform: translateY(0px);
      transition: transform 0.2s;
      z-index: 3;
    }
  }
  .mobile-filter-wrap.stick {
    position: fixed;
    top: 60px;
    width: 100%;
    z-index: 4;
    transition: transform 0.2s;
    transform: translateY(-60px);
  }

  /* Filter button (mobile) */
  .filter-btn {
    font-size: 16px;
    font-family: "BentonSansMedium", sans-serif;
    cursor: pointer;
  }
  @media (min-width: 769px) {
    .filter-btn {
      display: none;
    }
  }
  .filter-btn .icon-filter {
    background-image: url('/icons/filter-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    width: 17px;
    height: 14px;
    margin-right: 10px;
    display: inline-block;
  }

  /* Sort dropdown */
  .sort {
    position: relative;
    display: inline-flex;
  }
  @media (max-width: 768px) {
    .sort {
      font-size: 16px;
    }
  }
  .sort .sort-order {
    font-family: "BentonSansMedium", sans-serif;
    color: #878787;
    padding-left: 15px;
    min-width: 111px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  @media (max-width: 768px) {
    .sort .sort-order {
      padding-left: 5px;
      min-width: 80px;
    }
  }
  .sort .sort-order .icon-dropdown {
    margin-left: 20px;
    background-image: url('/icons/dropdown-icon.svg');
    background-repeat: no-repeat;
    background-size: cover;
    width: 12px;
    height: 7px;
    display: inline-block;
  }
  @media (max-width: 768px) {
    .sort .sort-order .icon-dropdown {
      background-image: url('/icons/sort-by-icon.svg');
      width: 8px;
      height: 14px;
      margin-left: 10px;
    }
  }
  .sort .sort-order-list {
    position: absolute;
    top: 30px;
    left: 65px;
    width: 110px;
    list-style-type: none;
    padding: 10px;
    box-shadow: 0px 0px 8px rgba(0, 0, 0, 0.2);
    background-color: #ffffff;
    z-index: 1;
    display: none;
  }
  @media (max-width: 768px) {
    .sort .sort-order-list {
      left: 49px;
      width: 100px;
    }
  }
  .sort .sort-order-list .sort-option {
    font-family: "BentonSansMedium", sans-serif;
    color: #878787;
    padding: 5px;
    cursor: pointer;
  }

  /* Holidays container with vertical divider */
  .holidays {
    position: relative;
  }
  @media (min-width: 769px) {
    .holidays:before {
      content: "";
      position: absolute;
      left: -32px;
      height: 100%;
      width: 1px;
      background: rgba(0, 0, 0, 0.2);
    }
  }
  @media (max-width: 768px) {
    .holidays {
      max-width: 730px;
      margin-left: auto;
      margin-right: auto;
    }
  }
  @media (max-width: 760px) {
    .holidays { max-width: 580px; }
  }
  @media (max-width: 610px) {
    .holidays { max-width: 500px; }
  }
  @media (max-width: 530px) {
    .holidays { max-width: 420px; }
  }
  @media (max-width: 450px) {
    .holidays { max-width: 365px; }
  }
  @media (max-width: 394px) {
    .holidays { max-width: 335px; }
  }
  @media (max-width: 350px) {
    .holidays { max-width: 290px; }
  }

  /* Holiday card */
  .holiday {
    box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.08);
    display: flex;
    margin-top: 20px;
    position: relative;
  }
  @media (max-width: 1100px) {
    .holiday {
      flex-direction: column;
    }
  }
  @media (max-width: 768px) {
    .holiday {
      flex-direction: row;
    }
  }
  @media (max-width: 760px) {
    .holiday {
      flex-direction: column;
    }
  }

  /* Holiday image */
  .holiday .holiday-img {
    min-width: 291px;
    display: block;
    background-size: cover;
    background-repeat: no-repeat;
    height: 340px;
  }
  @media (max-width: 1100px) {
    .holiday .holiday-img { width: 567px; }
  }
  @media (max-width: 940px) {
    .holiday .holiday-img { width: 417px; }
  }
  @media (max-width: 768px) {
    .holiday .holiday-img { width: 291px; }
  }
  @media (max-width: 760px) {
    .holiday .holiday-img { width: 580px; }
  }
  @media (max-width: 610px) {
    .holiday .holiday-img { width: 500px; }
  }
  @media (max-width: 530px) {
    .holiday .holiday-img { width: 420px; }
  }
  @media (max-width: 450px) {
    .holiday .holiday-img { width: 365px; }
  }
  @media (max-width: 394px) {
    .holiday .holiday-img {
      width: 335px;
      height: 210px;
    }
  }
  @media (max-width: 350px) {
    .holiday .holiday-img { width: 284px; }
  }

  /* Gallery link overlay */
  .holiday .gallery-link {
    display: flex;
    align-items: center;
    flex-direction: column;
    justify-content: center;
    position: absolute;
    top: 236px;
    left: 0px;
    width: 104px;
    height: 104px;
    background-color: rgba(0, 0, 0, 0.6);
    color: #ffffff;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    text-decoration: none;
  }
  @media (max-width: 394px) {
    .holiday .gallery-link {
      width: 64px;
      height: 64px;
      top: 146px;
      font-size: 12px;
    }
  }
  .holiday .gallery-link .icon-camera {
    width: 35px;
    height: 29px;
    margin-bottom: 10px;
    background-image: url('/icons/camera-icon.svg');
    background-size: contain;
    background-repeat: no-repeat;
    display: block;
  }
  @media (max-width: 394px) {
    .holiday .gallery-link .icon-camera {
      width: 24px;
      height: 20px;
      margin-bottom: 5px;
    }
  }

  /* Details section */
  .holiday .details {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 30px;
    width: 100%;
  }
  @media (max-width: 450px) {
    .holiday .details {
      padding: 20px;
    }
  }
  .holiday .details .title {
    font-family: "BentonSansBold", sans-serif;
    font-size: 24px;
    line-height: 27px;
    color: #424242;
  }
  @media (max-width: 450px) {
    .holiday .details .title {
      font-size: 20px;
    }
  }
  .holiday .details ul {
    list-style-type: none;
    padding-top: 5px;
    padding-bottom: 20px;
    display: flex;
  }
  @media (max-width: 1260px) {
    .holiday .details ul {
      flex-direction: column;
    }
  }
  @media (max-width: 1100px) {
    .holiday .details ul {
      flex-direction: row;
    }
  }
  @media (max-width: 940px) {
    .holiday .details ul {
      flex-direction: column;
    }
  }
  .holiday .details ul li {
    display: inline-flex;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    color: #878787;
    align-items: center;
    padding-right: 20px;
  }
  .holiday .details ul li .icon-compass {
    display: inline-block;
    width: 16px;
    height: 16px;
    background-image: url('/icons/compass-grey.svg');
    background-size: contain;
    background-repeat: no-repeat;
    padding-right: 10px;
    margin-right: 6px;
  }
  .holiday .details ul li .icon-nights {
    display: inline-block;
    width: 16px;
    height: 16px;
    background-image: url('/icons/nights-grey.svg');
    background-size: contain;
    background-repeat: no-repeat;
    padding-right: 10px;
    margin-right: 6px;
  }
  .holiday .details ul li .icon-board-basis {
    display: inline-block;
    width: 16px;
    height: 16px;
    background-image: url('/icons/board-basis-grey.svg');
    background-size: contain;
    background-repeat: no-repeat;
    padding-right: 10px;
    margin-right: 6px;
  }
  @media (max-width: 450px) {
    .holiday .details p {
      font-size: 12px;
    }
  }

  /* Horizontal bar with price and button */
  .holiday .details .horizontal {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .holiday .details .horizontal .price {
    display: inline-block;
  }
  .holiday .details .horizontal .price span {
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    line-height: 38px;
  }
  .holiday .details .horizontal .price div {
    font-family: "CaslonGraphiqueEF", serif;
    font-size: 40px;
    line-height: 38px;
  }
  @media (max-width: 610px) {
    .holiday .details .horizontal .price div {
      font-size: 34px;
    }
  }
  @media (max-width: 450px) {
    .holiday .details .horizontal .price div {
      font-size: 28px;
      line-height: 28px;
    }
  }
  @media (max-width: 394px) {
    .holiday .details .horizontal .price div {
      font-size: 26px;
    }
  }

  /* View More button */
  .view-more-btn {
    width: 185px;
    height: 64px;
    box-shadow: 0px 15px 15px rgba(0, 0, 0, 0.25);
    letter-spacing: 1px;
    margin-top: 0px;
    text-decoration: none;
  }
  .view-more-btn .icon-more {
    padding-left: 18px;
    width: auto;
    height: 12px;
  }
  @media (max-width: 1260px) {
    .view-more-btn .icon-more {
      padding-left: 13px;
    }
  }
  @media (max-width: 768px) {
    .view-more-btn .icon-more {
      padding-left: 8px;
    }
  }
  @media (max-width: 394px) {
    .view-more-btn .icon-more {
      padding-left: 5px;
    }
