---
import { footerDestinations, footerCollections, footerUsefulLinks, contactInfo, disclaimer } from '../data/footer';
---

<footer class="footer-wrap text-white">
  <div class="section-container relative">
    <!-- Navigation Columns -->
    <div class="footer-nav flex flex-col md:flex-row justify-between">
      <!-- Destinations -->
      <div class="footer-col footer-lhs">
        <div class="footer-accordion-header flex items-center justify-between cursor-pointer md:cursor-default" data-accordion="destinations">
          <h3 class="footer-heading font-display text-white">Destinations</h3>
          <img src="/icons/dropdown-icon.svg" alt="" class="w-3 h-3 md:hidden transition-transform footer-accordion-icon brightness-0 invert" />
        </div>
        <ul class="footer-accordion-content hidden md:flex md:flex-wrap footer-links">
          {footerDestinations.map((item) => (
            <li class="md:w-1/2">
              <a href={item.href} class="text-white/70 hover:text-primary transition-colors">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Collections -->
      <div class="footer-col footer-mid">
        <div class="footer-accordion-header flex items-center justify-between cursor-pointer md:cursor-default" data-accordion="collections">
          <h3 class="footer-heading font-display text-white">Collections</h3>
          <img src="/icons/dropdown-icon.svg" alt="" class="w-3 h-3 md:hidden transition-transform footer-accordion-icon brightness-0 invert" />
        </div>
        <ul class="footer-accordion-content hidden md:flex md:flex-wrap footer-links">
          {footerCollections.map((item) => (
            <li class="md:w-1/2">
              <a href={item.href} class="text-white/70 hover:text-primary transition-colors">
                {item.name}
              </a>
            </li>
          ))}
          <li class="md:w-1/2">
            <a href="/collections" class="text-primary font-medium underline">View All</a>
          </li>
        </ul>
      </div>

      <!-- Useful Links -->
      <div class="footer-col footer-rhs">
        <div class="footer-accordion-header flex items-center justify-between cursor-pointer md:cursor-default" data-accordion="useful">
          <h3 class="footer-heading font-display text-white">Useful Links</h3>
          <img src="/icons/dropdown-icon.svg" alt="" class="w-3 h-3 md:hidden transition-transform footer-accordion-icon brightness-0 invert" />
        </div>
        <ul class="footer-accordion-content hidden md:block footer-links">
          {footerUsefulLinks.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-primary transition-colors">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Contact & Legal -->
    <div class="footer-contacts flex flex-col sm:flex-row items-center gap-6">
      <div class="flex items-center gap-4">
        <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-white hover:text-primary transition-colors">
          <img src="/icons/phone-icon.svg" alt="" class="w-4 h-4 brightness-0 invert" />
          <span class="font-bold">{contactInfo.phone}</span>
        </a>
        <a href={`mailto:${contactInfo.email}`} class="flex items-center gap-2 text-white/70 hover:text-primary transition-colors text-sm">
          <img src="/icons/email-icon.svg" alt="" class="w-4 h-4 brightness-0 invert" />
          <span>{contactInfo.email}</span>
        </a>
      </div>
      <img src="/images/atol.png" alt="ATOL Protected" class="h-12" />
      <img src="/images/clia-logo.png" alt="CLIA Member" class="h-12" />
      <img src="/images/travel-trust.png" alt="Travel Trust" class="h-12" />
    </div>

    <!-- Agent Reference Search -->
    <div class="ref-search">
      <form id="ref-search-form" class="ref-search__form">
        <label for="ref-input" class="ref-search__label">Agent reference lookup</label>
        <div class="ref-search__row">
          <input id="ref-input" type="text" inputmode="numeric" pattern="[0-9]*" placeholder="Enter reference number" class="ref-search__input" required />
          <button type="submit" class="ref-search__btn">Go</button>
        </div>
      </form>
    </div>

    <!-- Disclaimer -->
    <p class="footer-disclaimer">{disclaimer}</p>

    <!-- Copyright -->
    <div class="footer-copyright text-center text-white">
      &copy; Flights and Packages {new Date().getFullYear()}
    </div>

    <!-- Return to top -->
    <button
      type="button"
      id="return-to-top"
      class="return-top hidden md:flex flex-col items-center gap-1 text-white/50 hover:text-white transition-colors cursor-pointer absolute"
    >
      <img src="/icons/return-top-icon.svg" alt="" class="w-5 h-5 brightness-0 invert" />
      <span class="text-xs">Return to top</span>
    </button>
  </div>
</footer>

<style>
  .footer-wrap {
    background-color: #000000;
    padding-top: 80px;
  }
  @media (max-width: 760px) { .footer-wrap { padding-top: 40px; } }
  @media (max-width: 450px) { .footer-wrap { padding-top: 20px; } }
  @media (max-width: 350px) { .footer-wrap { padding-top: 0px; } }

  .footer-heading {
    font-size: 24px;
  }

  .footer-nav {
    gap: 0;
  }

  .footer-col {
    flex: 1;
  }
  .footer-lhs {
    flex: 2;
  }
  .footer-mid {
    flex: 2;
    margin-left: 100px;
    padding-left: 145px;
    border-left: 1px solid rgba(255,255,255,0.15);
  }
  .footer-rhs {
    padding-left: 145px;
    border-left: 1px solid rgba(255,255,255,0.15);
  }
  @media (max-width: 1260px) {
    .footer-mid { margin-left: 50px; padding-left: 75px; }
    .footer-rhs { padding-left: 75px; }
  }
  @media (max-width: 940px) {
    .footer-mid { margin-left: 30px; padding-left: 40px; }
    .footer-rhs { padding-left: 40px; }
  }
  @media (max-width: 768px) {
    .footer-nav { flex-direction: column; }
    .footer-mid, .footer-rhs {
      margin-left: 0;
      padding-left: 0;
      border-left: none;
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 15px;
      margin-top: 15px;
    }
  }

  .footer-links {
    margin-top: 45px;
  }
  @media (max-width: 768px) { .footer-links { margin-top: 10px; } }

  .footer-links li {
    font-size: 14px;
    line-height: 34px;
  }

  .footer-contacts {
    margin-top: 90px;
  }
  @media (max-width: 768px) { .footer-contacts { margin-top: 40px; } }

  .footer-disclaimer {
    font-size: 9px !important;
    line-height: 14px !important;
    color: rgba(255,255,255,0.5) !important;
    margin-top: 65px;
  }
  @media (max-width: 768px) { .footer-disclaimer { margin-top: 30px; } }

  .footer-copyright {
    font-size: 14px;
    margin-bottom: 70px;
  }
  @media (max-width: 768px) { .footer-copyright { margin-bottom: 30px; } }

  .ref-search {
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .ref-search__label {
    font-family: "BentonSans", sans-serif;
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    margin-bottom: 8px;
  }
  .ref-search__row {
    display: flex;
    gap: 8px;
    max-width: 280px;
  }
  .ref-search__input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    background: rgba(255,255,255,0.08);
    color: #fff;
    font-family: "BentonSans", sans-serif;
    font-size: 14px;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }
  .ref-search__input::placeholder { color: rgba(255,255,255,0.3); }
  .ref-search__input:focus { border-color: #20A1AA; }
  .ref-search__btn {
    padding: 8px 18px;
    background: #20A1AA;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-family: "BentonSansMedium", sans-serif;
    font-size: 14px;
    cursor: pointer;
    transition: background-color 0.15s;
  }
  .ref-search__btn:hover { background: #1a8a92; }

  .return-top {
    right: -125px;
    top: 0;
  }
  @media (max-width: 1260px) { .return-top { right: 0; top: auto; bottom: 30px; } }
</style>

<script>
  // Footer accordion (mobile)
  document.querySelectorAll('.footer-accordion-header').forEach((header) => {
    header.addEventListener('click', () => {
      if (window.innerWidth >= 768) return;
      const content = header.nextElementSibling as HTMLElement;
      const icon = header.querySelector('.footer-accordion-icon') as HTMLElement;
      if (content) {
        content.classList.toggle('hidden');
      }
      if (icon) {
        icon.classList.toggle('rotate-180');
      }
    });
  });

  // Return to top
  document.getElementById('return-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Reference lookup
  document.getElementById('ref-search-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = document.getElementById('ref-input') as HTMLInputElement;
    const id = input.value.trim();
    if (id) window.location.href = `/api/ref?id=${encodeURIComponent(id)}`;
  });
</script>
