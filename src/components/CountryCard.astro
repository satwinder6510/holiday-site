---
interface Props {
  name: string;
  region: string;
  image: string;
  href: string;
}

const { name, region, image, href } = Astro.props;
---

<a
  href={href}
  class="country-card flex-shrink-0 relative bg-cover bg-no-repeat bg-center block"
  style={`background-image: url('${image}')`}
  title={name}
>
  <div class="country-gradient"></div>
  <div class="country-content absolute text-white z-[1]">
    <div class="country-name font-display text-left">{name}</div>
    <div class="country-region text-left">{region}</div>
  </div>
</a>

<style>
  .country-card {
    height: 424px;
    width: 291px;
    margin: 30px 12.5px 0;
    position: relative;
    overflow: hidden;
  }
  @media (max-width: 759px) {
    .country-card { height: 360px; width: 247px; }
  }
  @media (max-width: 529px) {
    .country-card { height: 271px; width: 186px; margin: 30px 5px 0; }
  }

  .country-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.6));
  }

  .country-content {
    bottom: 27px;
    left: 27px;
  }
  @media (max-width: 759px) { .country-content { bottom: 20px; left: 20px; } }
  @media (max-width: 529px) { .country-content { bottom: 15px; left: 15px; } }

  .country-name {
    font-size: 30px;
    line-height: 27px;
  }
  @media (max-width: 759px) { .country-name { font-size: 24px; } }
  @media (max-width: 529px) { .country-name { font-size: 20px; } }

  .country-region {
    font-size: 16px;
    line-height: 24px;
  }
  @media (max-width: 759px) { .country-region { font-size: 14px; } }
</style>
