---
import { featuredTour as fallbackTour } from '../data/featuredTour';
import type { FeaturedTourData } from '../lib/api';

interface Props {
  tour?: FeaturedTourData;
}

const featuredTour = Astro.props.tour || fallbackTour;
---

<section class="featured-tour-section">
  <div class="featured-inner">
    <!-- Left: text content -->
    <div class="featured-text">
      <p class="section-label">featured tours</p>
      <h2>{featuredTour.title}</h2>
      <p>{featuredTour.description}</p>
      <div class="featured-price">
        <span class="price-label">from</span>
        <div class="price-amount font-display">{featuredTour.price}<span class="price-pp">/pp</span></div>
      </div>
      <a href={featuredTour.href} class="btn-primary featured-btn">
        Learn More
        <img src="/icons/more-icon-white.svg" alt="" class="pl-[18px]" />
      </a>
    </div>

    <!-- Right: image carousel + nav -->
    <div class="featured-gallery">
      <div id="featured-viewport" class="featured-viewport">
        <div id="featured-container" class="featured-container">
          {featuredTour.images.map((img) => (
            <div class="featured-slide" style={`background-image: url('${img}')`}></div>
          ))}
        </div>
      </div>
      <div class="featured-navigation">
        <button type="button" id="featured-prev" class="feat-nav-btn">
          <img src="/icons/arrow-icon.svg" alt="Previous" class="h-[14px] rotate-180 brightness-0 invert" />
        </button>
        <button type="button" id="featured-next" class="feat-nav-btn">
          <img src="/icons/arrow-icon.svg" alt="Next" class="h-[14px] brightness-0 invert" />
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .featured-tour-section {
    background: linear-gradient(135deg, #484848, #000000);
    color: white;
  }

  .featured-inner {
    display: flex;
    max-width: 1240px;
    margin: 0 auto;
    min-height: 480px;
  }

  /* Left text column */
  .featured-text {
    flex: 0 0 45%;
    padding: 80px 40px 80px 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-text .section-label {
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 14px;
  }

  .featured-text h2 {
    color: white !important;
    margin-bottom: 0;
  }

  .featured-text p {
    color: rgba(255, 255, 255, 0.85);
    margin-top: 20px;
    line-height: 1.7;
    max-width: 420px;
  }

  .featured-price {
    margin-top: 28px;
  }

  .price-label {
    font-size: 14px;
    font-weight: 500;
    line-height: 30px;
  }

  .price-amount {
    font-size: 40px;
  }

  .price-pp {
    font-size: 14px;
    font-weight: 500;
  }

  .featured-btn {
    width: 187px;
    height: 64px;
    margin-top: 28px;
    cursor: pointer;
  }

  /* Right gallery column */
  .featured-gallery {
    flex: 1;
    position: relative;
    max-height: 480px;
    align-self: center;
  }

  .featured-viewport {
    overflow: hidden;
    width: 100%;
    height: 480px;
  }

  .featured-container {
    display: flex;
    height: 100%;
  }

  :global(.featured-slide) {
    flex: 0 0 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* Nav arrows — bottom right of gallery */
  .featured-navigation {
    position: absolute;
    bottom: 0;
    right: 0;
    display: flex;
    z-index: 2;
  }

  .feat-nav-btn {
    width: 66px;
    height: 66px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    cursor: pointer;
    background: rgba(0, 0, 0, 0.6);
    transition: background-color 0.2s;
  }
  .feat-nav-btn:hover {
    background: rgba(0, 0, 0, 0.85);
  }

  /* Mobile: stack vertically, gallery on top */
  @media (max-width: 940px) {
    .featured-inner {
      flex-direction: column-reverse;
      min-height: unset;
    }

    .featured-text {
      flex: none;
      padding: 40px 20px 50px;
    }

    .featured-text p {
      max-width: 100%;
    }

    .featured-gallery {
      height: 380px;
    }

    .featured-btn {
      width: 139px;
      height: 45px;
      font-size: 12px;
      letter-spacing: 1px;
    }

    .price-amount {
      font-size: 32px;
    }
  }

  @media (max-width: 450px) {
    .featured-gallery {
      height: 280px;
    }

    .price-amount {
      font-size: 28px;
      line-height: 26px;
    }
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';

  const viewport = document.getElementById('featured-viewport')!;
  const embla = EmblaCarousel(viewport, { loop: true });
  (window as any).__featuredEmbla = embla;

  document.getElementById('featured-prev')?.addEventListener('click', () => embla.scrollPrev());
  document.getElementById('featured-next')?.addEventListener('click', () => embla.scrollNext());
</script>
