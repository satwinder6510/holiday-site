---
import CountryCard from './CountryCard.astro';
import { countries } from '../data/countries';
---

<section class="popular-countries relative overflow-hidden">
  <!-- World map background -->
  <div class="world-map absolute"></div>

  <div class="countries-description relative z-[1]">
    <h4>our most popular</h4>
    <h2>Countries</h2>
    <p class="text-sm text-secondary/80 leading-relaxed text-left">
      We put effort into all our wonderful holidays, with 55 beautiful locations to choose from. Our most popular packages include our curated India tours and our excellent value Cambodia and Vietnam tour. Our Italy holidays are also a popular choice with customers, and we offer a wide range - from short city breaks to all inclusive Italian beach holidays and multi-destination tours.
    </p>
  </div>

  <div class="countries-carousel relative z-[1]">
    <div id="countries-viewport" class="overflow-hidden">
      <div id="countries-container" class="flex">
        {countries.map((country) => (
          <CountryCard {...country} />
        ))}
      </div>
    </div>
  </div>

  <div class="countries-navigation absolute z-10">
    <button type="button" id="countries-next" class="next">
      <img src="/icons/arrow-icon.svg" alt="Next" class="h-[14px] brightness-0 invert" />
    </button>
  </div>
</section>

<style>
  .popular-countries {
    margin-bottom: 110px;
    margin-top: 50px;
    height: 594px;
    display: flex;
    align-items: center;
    max-width: 100%;
  }
  @media (max-width: 1260px) {
    .popular-countries {
      flex-direction: column;
      align-items: stretch;
      margin-bottom: 75px;
      height: auto;
    }
  }

  .world-map {
    left: 115px;
    background-image: url('/icons/world-map.svg');
    background-repeat: no-repeat;
    opacity: 0.05;
    height: 594px;
    width: 100%;
  }
  @media (max-width: 1260px) {
    .world-map { left: 0; top: -50px; }
  }

  .countries-description {
    padding-left: 335px;
    display: inline-block;
    padding-bottom: 30px;
  }
  @media (max-width: 1600px) { .countries-description { padding-left: 180px; } }
  @media (max-width: 1360px) { .countries-description { padding-left: 60px; } }
  @media (max-width: 1260px) {
    .countries-description {
      width: 1040px;
      padding: 0;
      margin: 0 auto;
      display: block;
    }
  }
  @media (max-width: 1100px) { .countries-description { width: 880px; } }
  @media (max-width: 940px) { .countries-description { width: 730px; } }
  @media (max-width: 760px) { .countries-description { width: 580px; margin: 0 auto; } }
  @media (max-width: 610px) { .countries-description { width: 500px; } }
  @media (max-width: 530px) { .countries-description { max-width: 420px; } }
  @media (max-width: 450px) { .countries-description { max-width: 365px; } }
  @media (max-width: 394px) { .countries-description { max-width: 335px; } }
  @media (max-width: 350px) { .countries-description { max-width: 290px; } }

  .countries-description p {
    margin-top: 16px;
    width: 422px;
  }
  @media (max-width: 1260px) {
    .countries-description p { width: 100%; }
  }

  .countries-carousel {
    position: absolute;
    padding-left: 865px;
    display: inline-block;
  }
  @media (max-width: 1600px) { .countries-carousel { padding-left: 710px; } }
  @media (max-width: 1360px) { .countries-carousel { padding-left: 590px; } }
  @media (max-width: 1260px) {
    .countries-carousel {
      position: static;
      max-width: 1040px;
      margin: 0 auto;
      padding-left: 0;
    }
  }
  @media (max-width: 1100px) { .countries-carousel { max-width: 880px; } }
  @media (max-width: 940px) { .countries-carousel { max-width: 730px; } }
  @media (max-width: 760px) { .countries-carousel { max-width: 580px; } }
  @media (max-width: 610px) { .countries-carousel { max-width: 500px; } }
  @media (max-width: 530px) { .countries-carousel { max-width: 420px; } }
  @media (max-width: 450px) { .countries-carousel { max-width: 365px; } }
  @media (max-width: 394px) { .countries-carousel { max-width: 335px; } }
  @media (max-width: 350px) { .countries-carousel { max-width: 290px; } }

  .countries-navigation {
    top: 260px;
    left: 830px;
  }
  @media (max-width: 1600px) { .countries-navigation { left: 675px; } }
  @media (max-width: 1360px) { .countries-navigation { left: 555px; } }
  @media (max-width: 1260px) { .countries-navigation { display: none; } }

  .countries-navigation button {
    width: 66px;
    height: 66px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.6);
    border: 0;
    cursor: pointer;
  }
  @media (max-width: 768px) {
    .countries-navigation button { width: 40px; height: 40px; }
    .countries-navigation button img { height: 10px; }
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';

  const viewport = document.getElementById('countries-viewport')!;
  const embla = EmblaCarousel(viewport, {
    align: 'start',
    containScroll: 'trimSnaps',
    dragFree: true,
    slidesToScroll: 3,
  });

  document.getElementById('countries-next')?.addEventListener('click', () => embla.scrollNext());
</script>
