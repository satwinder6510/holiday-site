@model citrus.Models.header

<footer>
    <section>
        <div class="navigation">
            <div class="lhs">
                <div class="header footer-mobile-accordion"><h3>Destinations</h3><span class="icon-dropdown"></span></div>
                <ul>
                    @foreach (var item in Model.destinations)
                    {
                        <li><a href="/Holidays/@item.Destination.Replace(" ","-")">@item.Destination</a></li>
                    }
                </ul>
            </div>
            <div class="mid">
                <div class="header footer-mobile-accordion"><h3>Collections</h3><span class="icon-dropdown"></span></div>
                <ul class="list-flex-wrap">                   
                    @foreach (var item in Model.collections.Take(12))
                    {
                        <li><a href="/Holidays/@item.Value">@item.Text</a></li>
                    }
                    <li><a href="/Greek-Island-Hopping">Greek Island Hopping</a></li>
                    <li><a href="/Vietnam-and-cambodia-holidays">Vietnam and Cambodia</a></li>
                    <li><a href="/Golden-triangle-holidays">India Golden Triangle</a></li>
                    @if (Model.collections.Count() > 12)
                    {
                        <li class="view-all"><a href="/collections">View All</a></li>
                    }                    
                </ul>
            </div>
            <div class="rhs">
                <div class="header footer-mobile-accordion"><h3>Useful Links</h3><span class="icon-dropdown"></span></div>
                <ul>
                    <li><a href="/Holidays/SpecialOffer">Offers</a></li>
                    <li><a href="/blog">Blogs</a></li>
					<li><a href="/AboutUs">About</a></li>
                    <li><a href="/Home/Contact_Us">Contact</a></li>
                    <li><a href="/TermNcondition">Terms & Conditions</a></li>
                    <li><a href="/PrivacyPolicy">Privacy Policy</a></li>
                    @*<li><a href="/cookiespolicy">Cookies Policy</a></li>*@
                </ul>
            </div>
        </div>
        <div class="contacts">
            <div class="contact-wrap">
                <a class="phone" href="tel:@Model.dynamicphonenumber"><span class="icon-phone"></span>@Model.dynamicphonenumber</a>
                <a class="email" href="mailto:info@citiesandbeaches.com"><span class="icon-email"></span> info@citiesandbeaches.com</a>
                <div class="social-media">
                  <!--  <a href="#"><span class="icon-facebook"></span></a>
                    <a href="#"><span class="icon-twitter"></span></a>
                    <a href="#"><span class="icon-pinterest"></span></a>-->
                </div>
            </div>
            <div class="legal">
              <!--  <span class="icon-atol"></span>
                <span class="icon-iata"></span>-->
            </div>
        </div>
        <div class="disclaimer">Many of the flights and flight-inclusive holidays on this website are financially protected by the ATOL scheme. But ATOL protection does not apply to all holiday and travel services listed on this website. Please ask us to confirm what protection may apply to your booking. If you do not receive an ATOL Certificate then the booking will not be ATOL protected. If you do receive an ATOL Certificate but all the parts of your trip are not listed on it, those parts will not be ATOL protected. Please see our booking conditions for information, or for more information about financial protection and the ATOL Certificate go to: <strong>www.atol.org.uk/ATOLCertificate</strong></div>
        <div class="partners">
            <span class="logo-emirates"></span>
            <span class="logo-ba"></span>
            <span class="logo-cathy"></span>
            <span class="logo-iberia"></span>
            <span class="logo-lufthansa"></span>
            <span class="logo-malaysia"></span>
            <span class="logo-singapore"></span>
            <span class="logo-eva"></span>
            <span class="logo-turkish"></span>
            <span class="logo-vietnam"></span>
        </div>
        <div class="copyright">
            <div class="cities"><span class="icon">© </span> Cities and Beaches 2021</div>
           </div>
        <div class="return-top scroll">
            <span class="icon-return"></span>
            <div>Return to top</div>
        </div>
    </section>
</footer>

<div class="call-now-m">
    <a href="tel:@Model.dynamicphonenumber">
        <span>call now </span>
        @Model.dynamicphonenumber
    </a>
</div>
