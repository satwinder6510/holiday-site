<body>
    <!-- Google Tag Manager -->
    <noscript>
        <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5NSCJW"
                height="0" width="0" class="disp-visi-none"></iframe>
    </noscript>
    <!--End Google Tag Manager -->
    @Html.Action("header", "home")
    @*<div class="loader"></div>*@
    <a data-provide="lity" id="msgboxbtn" href="#msgbox" data-lity style="display:none">CLick</a>
    <div class="success-popup lity-hide" id="msgbox">
        <p class="bold">Thank you for your query</p>
        <p>We will respond to you shortly</p>
        <button class="btn" data-lity-close>Close</button>
    </div>

    <a data-provide="lity" id="nlboxbtn" href="#nlbox" data-lity style="display:none">CLick</a>
    <div class="success-popup lity-hide" id="nlbox">
        <p class="bold">Thank you for subscribing to our Newsletter.</p>
        <button class="btn" data-lity-close>Close</button>
    </div>

    <div class="success-popup lity-hide" id="callback" style="background-color:#fff; padding: 10px !important; border-radius: 8px; margin: 5px;">
        <h4 style="color:#000">Please fill in the form below<span style="float:right;cursor: pointer;" data-lity-close>X</span></h4>
        <div class="contact-form" style="background-color:#f8f8f8; padding:10px 5px 5px; width:100%; font-size:14px; font-family:Verdana, Geneva, sans-serif;">
            <form>
                <div class="field-wrap con-form-cal-2">
                    <label>Name<span> (Required)</span></label>
                    <input type="text" required id="rcb_name">
                </div>
                <div class="field-wrap con-form-cal-2">
                    <label>Email<span> (Required)</span></label>
                    <input type="text" required id="rcb_email">
                </div>
                <div class="field-wrap con-form-cal-2">
                    <label>Phone number<span> (Required)</span></label>
                    <input type="number" required id="rcb_phn">
                </div>
                <div class="form-block con-form-cal-1">
                    <label>Comment <span> (Required)</span></label>
                    <textarea id="rcb_comment" rows="4" required></textarea>
                </div>
                <div class="form-block con-form-cal-2">
                    <div class="form-reset" style="padding-top: 5px;">
                        <a href="javascript:void(0)" onclick="$('form').trigger('reset')">Reset all fields</a>
                    </div>
                </div>
                <div class="form-block con-form-cal-2">
                    <button class="btn submit" type="button" id="btRequestCallBack" style="margin-top: 10px;">Submit</button>
                </div>
                <div style="clear:both;"></div>
            </form>
        </div>
    </div>

    @RenderBody()
    @Html.Action("footer", "home")


    @Scripts.Render("~/bundles/common")

    
