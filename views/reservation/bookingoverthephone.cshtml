    <style type="text/css">
        body {
            background: url("/assets/img/splash-bg.jpg") no-repeat;
            background-size: cover;
            object-fit: cover;
            background-position: 50% 30%;
        }

        .body-over-the-phone {
            width: 80%;
            margin: 10px auto 40px auto;
            max-width: 800px;
            padding: 35px 45px;
            background: rgba(255, 255, 255, 0.70);
            color: #424242;
            border-radius: 12px;
        }

        .page-logo {
            width: 100%;
            margin: 50px auto 10px auto;
            max-width: 800px;
            text-align: center;
        }

            .page-logo img {
                width: 400px;
                height: auto;
                text-shadow: 0px 0px 9px rgba(0,0,0,0.63);
            }

        .body-over-the-phone h3 {
            margin: 0px 0 16px;
            font-size: 29px;
            text-align: center;
        }

        .body-over-the-phone p {
            font-size: 14px;
            line-height: 30px;
            font-weight: normal;
        }

            .body-over-the-phone p span {
                font-size: 16px;
                font-weight: bold;
            }

        .text-center {
            text-align: center;
        }

        .btn-phone .btn {
            cursor: pointer;
            width: 200px;
            height: 54px;
            margin: 0 auto;
            letter-spacing: 1px;
        }

            .btn-phone .btn .icon-more {
                padding-left: 18px;
                content: url("/assets/img/more-icon-white.svg");
                margin-bottom: -1px;
            }

        @@media(max-width:414px) {
            .body-over-the-phone {
                width: 90%;
                padding: 25px 35px;
            }

            .page-logo img {
                width: 250px;
            }

            .body-over-the-phone h3 {
                font-size: 25px;
            }
        }
    </style>
