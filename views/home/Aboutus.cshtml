@if (Model.MetaDetails != null)
{
    @section AdditionalMeta
{
        <title>About Us | Flights and Packages</title>
        <meta name="keywords" content="@Model.MetaDetails.MetaKeyword.Replace("Flights and Packages  Holidays", "Holidays - Flights and Packages")" />
        <meta name="description" content="Flights and Packages offer high-quality, tailor-made tours and holidays at the best possible price, with 55 destinations to choose from." />
        @if (!string.IsNullOrEmpty(Model.MetaDetails.canonicalTag.Replace("www.citiesandbeaches.com", "holidays.flightsandpackages.com")))
        {
            <link rel="canonical" href="@Html.Raw(Model.MetaDetails.canonicalTag.Replace("www.citiesandbeaches.com", "holidays.flightsandpackages.com"))" />
        }
    }
}
